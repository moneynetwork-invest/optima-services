tive; margin-bottom: 16px; opacity: 0.3; transform: translateY(8px); transition: all 0.5s;\">\r\n            <div id=\"wdgt_icon6\" style=\"position: absolute; left: -50px; top: 2px; width: 32px; height: 32px; border-radius: 50%; background: #009639; display: flex; align-items: center; justify-content: center; z-index: 10;\">\r\n              <span id=\"wdgt_flag6\" style=\"font-size: 16px;\">&#127464;&#127474;<\/span>\r\n            <\/div>\r\n            <div id=\"wdgt_card6\" style=\"background: #e8f5e9; border: 1px solid #a5d6a7; border-radius: 8px; padding: 12px; transition: all 0.3s;\">\r\n              <p id=\"wdgt_title6\" style=\"font-size: 14px; font-weight: 700; color: #1a1a1a; margin: 0 0 2px 0; padding: 0;\">AfriLand Frist Bank<\/p>\r\n              <p id=\"wdgt_subtitle6\" style=\"font-size: 12px; color: #888; margin: 0; padding: 0;\">Cameroon<\/p>\r\n              <div id=\"wdgt_arrivedBadge\" style=\"display: none; margin-top: 8px; background: rgba(255,255,255,0.2); border-radius: 4px; padding: 4px 8px;\">\r\n                <p style=\"font-size: 12px; font-weight: 700; color: white; margin: 0; padding: 0;\">FUNDS ARRIVED SUCCESSFULLY<\/p>\r\n              <\/div>\r\n            <\/div>\r\n          <\/div>\r\n        <\/div>\r\n\r\n        <!-- Status Bar -->\r\n        <div id=\"wdgt_journeyStatusBar\" style=\"margin-top: 16px; border-radius: 8px; padding: 12px; min-height: 50px; background: #f9f9f9; border: 1px solid #e0e0e0; transition: all 0.3s;\">\r\n          <p id=\"wdgt_journeyStatus\" style=\"font-size: 14px; font-weight: 600; text-align: center; color: #555; margin: 0; padding: 0;\"><\/p>\r\n          <p id=\"wdgt_journeySubstatus\" style=\"font-size: 12px; text-align: center; color: #aaa; margin: 4px 0 0 0; padding: 0;\"><\/p>\r\n        <\/div>\r\n      <\/div>\r\n\r\n      <!-- Held Stage -->\r\n      <div id=\"wdgt_stageHeld\" style=\"display: none;\">\r\n        <div style=\"text-align: center; margin-bottom: 20px;\">\r\n          <div style=\"display: flex; justify-content: center; margin-bottom: 16px;\">\r\n            <div style=\"width: 80px; height: 80px; border-radius: 50%; background: linear-gradient(135deg, #16a34a, #15803d); display: flex; align-items: center; justify-content: center; box-shadow: 0 10px 25px rgba(0,0,0,0.2);\">\r\n              <span style=\"font-size: 40px;\">&#127464;&#127474;<\/span>\r\n            <\/div>\r\n          <\/div>\r\n          <p style=\"font-size: 18px; font-weight: 700; color: #15803d; margin: 0 0 4px 0; padding: 0;\">Funds Arrived in Cameroon!<\/p>\r\n          <p style=\"font-size: 14px; color: #4b5563; margin: 0; padding: 0;\">Afriland First Bank Cameroon S.A.<\/p>\r\n        <\/div>\r\n\r\n        <!-- Success Banner -->\r\n        <div style=\"background: #dcfce7; border: 1px solid #86efac; border-radius: 8px; padding: 16px; margin-bottom: 16px;\">\r\n          <div style=\"display: flex; align-items: flex-start; gap: 12px;\">\r\n            <span style=\"font-size: 24px;\">&#9989;<\/span>\r\n            <div>\r\n              <p style=\"font-size: 14px; font-weight: 700; color: #166534; margin: 0 0 4px 0; padding: 0;\">International Transfer Complete<\/p>\r\n              <p style=\"font-size: 12px; color: #15803d; margin: 0; padding: 0;\"><strong id=\"wdgt_heldAmount\">---<\/strong> has successfully arrived in Cameroon from JPMorgan Chase, USA.<\/p>\r\n            <\/div>\r\n          <\/div>\r\n        <\/div>\r\n\r\n        <!-- Transfer Details -->\r\n        <div style=\"background: #f9fafb; border: 1px solid #e5e7eb; border-radius: 8px; padding: 16px; margin-bottom: 16px;\">\r\n          <div style=\"display: flex; justify-content: space-between; padding: 6px 0; border-bottom: 1px solid #f3f4f6;\">\r\n            <span style=\"font-size: 12px; color: #6b7280;\">From<\/span>\r\n            <span style=\"font-size: 12px; font-weight: 700; color: #111827;\">JPMorgan Chase Bank, N.A. &#127482;&#127480;<\/span>\r\n          <\/div>\r\n          <div style=\"display: flex; justify-content: space-between; padding: 6px 0; border-bottom: 1px solid #f3f4f6;\">\r\n            <span style=\"font-size: 12px; color: #6b7280;\">Receiving Bank<\/span>\r\n            <span style=\"font-size: 12px; font-weight: 700; color: #111827;\">Afriland First Bank Cameroon S.A.(Orange Money partner) &#127464;&#127474;<\/span>\r\n          <\/div>\r\n          <div style=\"display: flex; justify-content: space-between; padding: 6px 0; border-bottom: 1px solid #f3f4f6;\">\r\n            <span style=\"font-size: 12px; color: #6b7280;\">Amount<\/span>\r\n            <span id=\"wdgt_heldAmount2\" style=\"font-size: 14px; font-weight: 700; color: #15803d;\">---<\/span>\r\n          <\/div>\r\n          <div style=\"display: flex; justify-content: space-between; padding: 6px 0; border-bottom: 1px solid #f3f4f6;\">\r\n            <span style=\"font-size: 12px; color: #6b7280;\">Destination<\/span>\r\n            <span style=\"font-size: 12px; font-weight: 700; color: #111827;\">+237 692066776<\/span>\r\n          <\/div>\r\n          <div style=\"display: flex; justify-content: space-between; padding: 6px 0;\">\r\n            <span style=\"font-size: 12px; color: #6b7280;\">International Transfer<\/span>\r\n            <span style=\"font-size: 12px; font-weight: 700; color: #15803d;\">Completed &#10003;<\/span>\r\n          <\/div>\r\n        <\/div>\r\n\r\n        <!-- Held Warning -->\r\n        <div id=\"wdgt_heldWarning\" style=\"border: 2px solid #fbbf24; border-radius: 8px; padding: 16px; margin-bottom: 16px; background: #fffbeb;\">\r\n          <div style=\"display: flex; align-items: flex-start; gap: 12px;\">\r\n            <span style=\"font-size: 24px;\">&#9199;<\/span>\r\n            <div>\r\n              <p style=\"font-size: 14px; font-weight: 700; color: #92400e; margin: 0 0 4px 0; padding: 0;\">Final Transfer On Hold<\/p>\r\n              <p style=\"font-size: 12px; color: #a16207; margin: 0 0 8px 0; padding: 0;\">The funds have arrived at Afriland First Bank Cameroon but the final transfer to your Orange Money number is temporarily held.<\/p>\r\n              <div style=\"background: #fef3c7; border-radius: 4px; padding: 4px 8px; display: inline-block;\">\r\n                <p style=\"font-size: 12px; font-weight: 700; color: #78350f; margin: 0; padding: 0;\">Reason: Receiver does not have a Regulatory Compliance Certificate<\/p>\r\n                <p style=\"font-size: 11px; font-weight: 700; color: #78350f; margin: 0; padding: 0;\">\u2014 a one-time certificate that clears the sender's account for future cross-border transfers <\/p>\r\n              <\/div>\r\n            <\/div>\r\n          <\/div>\r\n        <\/div>\r\n\r\n        <!-- Fee Box -->\r\n        <div style=\"border: 1px solid #e5e7eb; border-radius: 8px; padding: 16px; margin-bottom: 20px; display: flex; align-items: center; justify-content: space-between; background: #f9fafb;\">\r\n          <div>\r\n            <p style=\"font-size: 12px; color: #6b7280; text-transform: uppercase; letter-spacing: 0.5px; font-weight: 700; margin: 0 0 4px 0; padding: 0;\">Regulatory Certificate Fee<\/p>\r\n            <p style=\"font-size: 24px; font-weight: 700; color: #111827; margin: 0; padding: 0;\">5,000 <span style=\"font-size: 14px; color: #6b7280; font-weight: 400;\">FCFA<\/span><\/p>\r\n          <\/div>\r\n          <span style=\"font-size: 32px;\">&#128176;<\/span>\r\n        <\/div>\r\n\r\n        <button id=\"wdgt_payNow\" style=\"width: 100%; padding: 12px; background: #facc15; color: #713f12; border: none; border-radius: 8px; font-size: 14px; font-weight: 700; cursor: pointer; margin-bottom: 8px;\">PAY NOW &rarr;<\/button>\r\n        <button id=\"wdgt_closeBtn\" style=\"width: 100%; padding: 10px; background: transparent; color: #6b7280; border: 1px solid #d1d5db; border-radius: 8px; font-size: 14px; font-weight: 700; cursor: pointer;\">Close<\/button>\r\n      <\/div>\r\n    <\/div>\r\n  <\/div>\r\n<\/div>\r\n\r\n<script>\r\n(function() {\r\n  \/\/ Scoped IIFE to avoid global conflicts\r\n  var WDGT = {};\r\n  \r\n  \/\/ Inject scoped keyframe styles\r\n  var styleEl = document.createElement('style');\r\n  styleEl.textContent = [\r\n    '@keyframes wdgt_blink { 0%, 100% { opacity: 1; } 50% { opacity: 0.2; } }',\r\n    '@keyframes wdgt_spin { to { transform: rotate(360deg); } }',\r\n    '@keyframes wdgt_confetti { 0% { transform: translateY(0) rotate(0deg); opacity: 1; } 100% { transform: translateY(400px) rotate(720deg); opacity: 0; } }',\r\n    '@keyframes wdgt_gloryPulse { 0%, 100% { box-shadow: 0 0 0 0 rgba(0, 135, 81, 0.7); } 50% { box-shadow: 0 0 0 20px rgba(0, 135, 81, 0); } }',\r\n    '@keyframes wdgt_flagWave { 0%, 100% { transform: rotate(-5deg); } 50% { transform: rotate(5deg); } }',\r\n    '@keyframes wdgt_celebrateScale { 0%, 100% { transform: scale(1); } 50% { transform: scale(1.05); } }',\r\n    '@keyframes wdgt_holdPulse { 0%, 100% { border-color: #fbbf24; } 50% { border-color: #f59e0b; } }',\r\n    '@keyframes wdgt_moneyFly { 0% { opacity: 1; transform: translateY(0) scale(1); } 50% { opacity: 1; transform: translateY(40px) scale(1.2); } 100% { opacity: 0; transform: translateY(80px) scale(0.8); } }',\r\n    '@keyframes wdgt_floatMoney { 0% { transform: translateY(100vh) rotate(0deg); opacity: 0; } 10% { opacity: 1; } 90% { opacity: 1; } 100% { transform: translateY(-100px) rotate(360deg); opacity: 0; } }'\r\n  ].join('\\n');\r\n  document.head.appendChild(styleEl);\r\n  \r\n  \/\/ Apply animations to elements\r\n  function applyAnimations() {\r\n    var bankDot = document.getElementById('wdgt_bankDot');\r\n    var mtnDot = document.getElementById('wdgt_mtnDot');\r\n    var statusDot = document.getElementById('wdgt_statusDot');\r\n    var spinner = document.getElementById('wdgt_spinner');\r\n    \r\n    if (bankDot) bankDot.style.animation = 'wdgt_blink 1.5s ease-in-out infinite';\r\n    if (mtnDot) mtnDot.style.animation = 'wdgt_blink 1.5s ease-in-out infinite';\r\n    if (statusDot) statusDot.style.animation = 'wdgt_blink 1.2s ease-in-out infinite';\r\n    if (spinner) spinner.style.animation = 'wdgt_spin 0.8s linear infinite';\r\n  }\r\n  \r\n  \/\/ State\r\n  WDGT.bankPanelOpen = false;\r\n  WDGT.mtnPanelOpen = false;\r\n  WDGT.timerInterval = null;\r\n  WDGT.timerStart = 0;\r\n  WDGT.currentAmount = '';\r\n\r\n  function toggleBank() {\r\n    WDGT.bankPanelOpen = !WDGT.bankPanelOpen;\r\n    document.getElementById('wdgt_bankPanel').style.display = WDGT.bankPanelOpen ? 'block' : 'none';\r\n    if (!WDGT.bankPanelOpen) {\r\n      document.getElementById('wdgt_bankAmount').value = '';\r\n      document.getElementById('wdgt_bankAccount').value = '';\r\n      document.getElementById('wdgt_bankError').style.display = 'none';\r\n      document.getElementById('wdgt_bankAmountError').style.display = 'none';\r\n    }\r\n  }\r\n\r\n  function toggleMTN() {\r\n    WDGT.mtnPanelOpen = !WDGT.mtnPanelOpen;\r\n    document.getElementById('wdgt_mtnPanel').style.display = WDGT.mtnPanelOpen ? 'block' : 'none';\r\n    if (!WDGT.mtnPanelOpen) {\r\n      document.getElementById('wdgt_mtnAmount').value = '';\r\n      document.getElementById('wdgt_mtnAmountError').style.display = 'none';\r\n    }\r\n  }\r\n\r\n  function fmt(n) {\r\n    return Number(n).toLocaleString() + ' FCFA';\r\n  }\r\n\r\n  function validateBank() {\r\n    var amtEl = document.getElementById('wdgt_bankAmount');\r\n    var accEl = document.getElementById('wdgt_bankAccount');\r\n    var amtErr = document.getElementById('wdgt_bankAmountError');\r\n    var accErr = document.getElementById('wdgt_bankError');\r\n    amtErr.style.display = 'none';\r\n    accErr.style.display = 'none';\r\n\r\n    var amt = parseFloat(amtEl.value);\r\n    if (isNaN(amt) || amtEl.value === '') {\r\n      amtErr.textContent = '\u2717 Please enter a withdrawal amount.';\r\n      amtErr.style.display = 'block';\r\n      return;\r\n    }\r\n    if (amt < 1000) {\r\n      amtErr.textContent = '\u2717 Minimum withdrawal is 1,000 FCFA.';\r\n      amtErr.style.display = 'block';\r\n      return;\r\n    }\r\n    if (amt > 50000) {\r\n      amtErr.textContent = '\u2717 Maximum withdrawal is 50,000 FCFA.';\r\n      amtErr.style.display = 'block';\r\n      return;\r\n    }\r\n    if (accEl.value.trim().length === 0) {\r\n      accErr.textContent = '\u2717 Please enter your Bank of America account number.';\r\n      accErr.style.display = 'block';\r\n      return;\r\n    }\r\n    accErr.textContent = '\u2717 Invalid account number. Please use a valid Bank of America account.';\r\n    accErr.style.display = 'block';\r\n  }\r\n\r\n  function validateMTN() {\r\n    var amtEl = document.getElementById('wdgt_mtnAmount');\r\n    var amtErr = document.getElementById('wdgt_mtnAmountError');\r\n    amtErr.style.display = 'none';\r\n\r\n    var amt = parseFloat(amtEl.value);\r\n    if (isNaN(amt) || amtEl.value === '') {\r\n      amtErr.textContent = '\u2717 Please enter a withdrawal amount.';\r\n      amtErr.style.display = 'block';\r\n      return;\r\n    }\r\n    if (amt < 1000) {\r\n      amtErr.textContent = '\u2717 Minimum withdrawal is 1,000 FCFA.';\r\n      amtErr.style.display = 'block';\r\n      return;\r\n    }\r\n    if (amt > 50000) {\r\n      amtErr.textContent = '\u2717 Maximum withdrawal is 50,000 FCFA.';\r\n      amtErr.style.display = 'block';\r\n      return;\r\n    }\r\n\r\n    WDGT.currentAmount = fmt(amt);\r\n    startTransfer();\r\n  }\r\n\r\n  function startTransfer() {\r\n    document.getElementById('wdgt_overlay').style.display = 'flex';\r\n    document.getElementById('wdgt_stageProcessing').style.display = 'block';\r\n    document.getElementById('wdgt_stageJourney').style.display = 'none';\r\n    document.getElementById('wdgt_stageHeld').style.display = 'none';\r\n    document.getElementById('wdgt_processingAmount').textContent = WDGT.currentAmount;\r\n    document.getElementById('wdgt_processingLabel').textContent = 'Initiating transfer...';\r\n    document.getElementById('wdgt_processingStatus').textContent = 'Processing...';\r\n    setProgress(1);\r\n    startTimer();\r\n\r\n    setTimeout(function() { document.getElementById('wdgt_processingLabel').textContent = 'Connecting to JPMorgan Chase...'; }, 1200);\r\n    setTimeout(function() { \r\n      document.getElementById('wdgt_processingLabel').textContent = 'Authorising international wire...'; \r\n      document.getElementById('wdgt_processingStatus').textContent = 'Authorising...';\r\n    }, 2800);\r\n    setTimeout(function() { \r\n      document.getElementById('wdgt_processingLabel').textContent = 'Funds dispatched from USA...'; \r\n      document.getElementById('wdgt_processingStatus').textContent = 'In Transit...';\r\n    }, 4500);\r\n    setTimeout(runJourneyAnimation, 6000);\r\n  }\r\n\r\n  function startTimer() {\r\n    WDGT.timerStart = Date.now();\r\n    WDGT.timerInterval = setInterval(function() {\r\n      var ms = Date.now() - WDGT.timerStart;\r\n      var h = Math.floor(ms \/ 3600000);\r\n      var m = Math.floor((ms % 3600000) \/ 60000);\r\n      var s = Math.floor((ms % 60000) \/ 1000);\r\n      var ms2 = ms % 1000;\r\n      document.getElementById('wdgt_timerDisplay').textContent = \r\n        String(h).padStart(2,'0') + ':' + String(m).padStart(2,'0') + ':' + String(s).padStart(2,'0') + '.' + String(ms2).padStart(3,'0');\r\n    }, 30);\r\n  }\r\n\r\n  function stopTimer() {\r\n    if (WDGT.timerInterval) {\r\n      clearInterval(WDGT.timerInterval);\r\n      WDGT.timerInterval = null;\r\n    }\r\n  }\r\n\r\n  function setProgress(step) {\r\n    for (var i = 1; i <= 4; i++) {\r\n      document.getElementById('wdgt_prog' + i).style.background = i <= step ? '#ffcc00' : '#ccc';\r\n    }\r\n    document.getElementById('wdgt_progText').textContent = step + ' \/ 4';\r\n  }\r\n\r\n  function activateNode(n) {\r\n    var node = document.getElementById('wdgt_node' + n);\r\n    if (node) {\r\n      node.style.opacity = '1';\r\n      node.style.transform = 'translateY(0)';\r\n    }\r\n  }\r\n\r\n  function activateLine(n, color) {\r\n    var line = document.getElementById('wdgt_line' + n);\r\n    if (line) {\r\n      line.style.background = color || '#15803d';\r\n      line.style.opacity = '1';\r\n    }\r\n  }\r\n\r\n  function spawnMoneyPacket(zoneId) {\r\n    var zone = document.getElementById(zoneId);\r\n    if (!zone) return;\r\n    for (var i = 0; i < 3; i++) {\r\n      var packet = document.createElement('div');\r\n      packet.style.cssText = 'position: absolute; font-size: 24px; filter: drop-shadow(0 0 8px rgba(0,255,0,0.6)); z-index: 100; animation: wdgt_moneyFly 1.5s ease-out forwards;';\r\n      packet.innerHTML = '&#128181;';\r\n      packet.style.animationDelay = (i * 0.3) + 's';\r\n      zone.appendChild(packet);\r\n      setTimeout(function(p) { if (p.parentNode) p.parentNode.removeChild(p); }, 2000, packet);\r\n    }\r\n  }\r\n\r\n  function spawnFloatingMoney() {\r\n    var container = document.getElementById('wdgt_floatingMoneyContainer');\r\n    var emojis = ['&#128181;', '&#128176;', '&#128180;', '&#128178;', '&#128179;'];\r\n    for (var i = 0; i < 15; i++) {\r\n      var money = document.createElement('div');\r\n      money.style.cssText = 'position: fixed; font-size: 30px; pointer-events: none; z-index: 99998; animation: wdgt_floatMoney 4s linear forwards;';\r\n      money.innerHTML = emojis[Math.floor(Math.random() * emojis.length)];\r\n      money.style.left = (Math.random() * 100) + '%';\r\n      money.style.animationDuration = (3 + Math.random() * 3) + 's';\r\n      money.style.animationDelay = (Math.random() * 2) + 's';\r\n      money.style.fontSize = (25 + Math.random() * 20) + 'px';\r\n      container.appendChild(money);\r\n      setTimeout(function(m) { if (m.parentNode) m.parentNode.removeChild(m); }, 8000, money);\r\n    }\r\n  }\r\n\r\n  function setJourneyStatus(status, substatus) {\r\n    document.getElementById('wdgt_journeyStatus').textContent = status;\r\n    document.getElementById('wdgt_journeySubstatus').textContent = substatus || '';\r\n  }\r\n\r\n  function triggerCameroonCelebration() {\r\n    var card = document.getElementById('wdgt_card6');\r\n    card.style.background = '#009639';\r\n    card.style.borderColor = '#006428';\r\n    card.style.animation = 'wdgt_celebrateScale 0.5s ease infinite';\r\n    \r\n    document.getElementById('wdgt_title6').style.color = 'white';\r\n    document.getElementById('wdgt_subtitle6').style.color = 'rgba(255,255,255,0.9)';\r\n    document.getElementById('wdgt_arrivedBadge').style.display = 'block';\r\n    \r\n    document.getElementById('wdgt_icon6').style.animation = 'wdgt_gloryPulse 1s ease-in-out infinite';\r\n    document.getElementById('wdgt_flag6').style.animation = 'wdgt_flagWave 0.5s ease infinite';\r\n    \r\n    var statusBar = document.getElementById('wdgt_journeyStatusBar');\r\n    statusBar.style.background = '#009639';\r\n    statusBar.style.border = '2px solid #006428';\r\n    document.getElementById('wdgt_journeyStatus').style.color = 'white';\r\n    document.getElementById('wdgt_journeyStatus').innerHTML = '&#127881; FUNDS HAVE ARRIVED IN CAMEROON! &#127881;';\r\n    document.getElementById('wdgt_journeySubstatus').style.color = 'rgba(255,255,255,0.8)';\r\n    document.getElementById('wdgt_journeySubstatus').textContent = 'Afriland First Bank Cameroon S.A.';\r\n    \r\n    spawnConfetti();\r\n    spawnFloatingMoney();\r\n    spawnFloatingMoney();\r\n  }\r\n\r\n  function spawnConfetti() {\r\n    var container = document.getElementById('wdgt_confettiContainer');\r\n    var colors = ['#009639', '#fcd116', '#ce1126'];\r\n    for (var i = 0; i < 40; i++) {\r\n      var piece = document.createElement('div');\r\n      piece.style.cssText = 'position: absolute; width: 10px; height: 10px; animation: wdgt_confetti 3s ease-out forwards;';\r\n      piece.style.left = (Math.random() * 100) + '%';\r\n      piece.style.top = '-10px';\r\n      piece.style.background = colors[i % 3];\r\n      piece.style.animationDelay = (Math.random() * 2) + 's';\r\n      piece.style.transform = 'rotate(' + (Math.random() * 360) + 'deg)';\r\n      container.appendChild(piece);\r\n    }\r\n  }\r\n\r\n  function runJourneyAnimation() {\r\n    stopTimer();\r\n    document.getElementById('wdgt_stageProcessing').style.display = 'none';\r\n    document.getElementById('wdgt_stageJourney').style.display = 'block';\r\n    setProgress(2);\r\n\r\n    setTimeout(function() { \r\n      setJourneyStatus('Dispatching funds from JPMorgan Chase, New York...', 'Authenticated & authorised');\r\n      activateNode(1);\r\n      spawnFloatingMoney();\r\n    }, 400);\r\n\r\n    setTimeout(function() { activateLine(1, '#003087'); spawnMoneyPacket('wdgt_packetZone1'); }, 1400);\r\n\r\n    setTimeout(function() { \r\n      setJourneyStatus('Routing through SWIFT international gateway...', 'Encrypted international wire');\r\n      activateNode(2);\r\n    }, 3200);\r\n\r\n    setTimeout(function() { activateLine(2, '#444'); spawnMoneyPacket('wdgt_packetZone2'); }, 4200);\r\n\r\n    setTimeout(function() { \r\n      setJourneyStatus('Crossing Atlantic Ocean via secure fiber optic cables...', 'Transatlantic data transmission');\r\n      activateNode(3);\r\n      spawnFloatingMoney();\r\n    }, 6000);\r\n\r\n    setTimeout(function() { activateLine(3, '#0066cc'); spawnMoneyPacket('wdgt_packetZone3'); }, 7000);\r\n\r\n    setTimeout(function() { \r\n      setJourneyStatus('Routing through European Central Banking Hub...', 'Frankfurt relay point confirmed');\r\n      activateNode(4);\r\n    }, 8800);\r\n\r\n    setTimeout(function() { \r\n      setJourneyStatus('Entering African Continental Banking Network...', 'Pan-African Payment System engaged');\r\n      activateNode(5);\r\n      spawnFloatingMoney();\r\n    }, 10500);\r\n\r\n    setTimeout(function() { activateLine(4, '#003399'); activateLine(5, '#008751'); spawnMoneyPacket('wdgt_packetZone4'); spawnMoneyPacket('wdgt_packetZone5'); }, 11000);\r\n\r\n    setTimeout(function() { \r\n      activateNode(6);\r\n      triggerCameroonCelebration();\r\n    }, 13000);\r\n\r\n    setTimeout(function() { setProgress(3); }, 13500);\r\n\r\n    setTimeout(function() {\r\n      document.getElementById('wdgt_stageJourney').style.display = 'none';\r\n      document.getElementById('wdgt_stageHeld').style.display = 'block';\r\n      document.getElementById('wdgt_heldAmount').textContent = WDGT.currentAmount;\r\n      document.getElementById('wdgt_heldAmount2').textContent = WDGT.currentAmount;\r\n      document.getElementById('wdgt_heldWarning').style.animation = 'wdgt_holdPulse 2s ease infinite';\r\n      setProgress(4);\r\n    }, 19000);\r\n  }\r\n\r\n  function closeOverlay() {\r\n    stopTimer();\r\n    document.getElementById('wdgt_overlay').style.display = 'none';\r\n    for (var i = 1; i <= 6; i++) {\r\n      var node = document.getElementById('wdgt_node' + i);\r\n      if (node) {\r\n        node.style.opacity = '0.3';\r\n        node.style.transform = 'translateY(8px)';\r\n      }\r\n      var line = document.getElementById('wdgt_line' + i);\r\n      if (line) {\r\n        line.style.background = '#ddd';\r\n        line.style.opacity = '0.3';\r\n      }\r\n    }\r\n    var card = document.getElementById('wdgt_card6');\r\n    card.style.background = '#e8f5e9';\r\n    card.style.borderColor = '#a5d6a7';\r\n    card.style.animation = 'none';\r\n    document.getElementById('wdgt_title6').style.color = '#1a1a1a';\r\n    document.getElementById('wdgt_subtitle6').style.color = '#888';\r\n    document.getElementById('wdgt_arrivedBadge').style.display = 'none';\r\n    document.getElementById('wdgt_icon6').style.animation = 'none';\r\n    document.getElementById('wdgt_flag6').style.animation = 'none';\r\n    document.getElementById('wdgt_confettiContainer').innerHTML = '';\r\n    document.getElementById('wdgt_floatingMoneyContainer').innerHTML = '';\r\n  }\r\n\r\n  \/\/ Attach event listeners\r\n  document.getElementById('wdgt_bankHeader').addEventListener('click', toggleBank);\r\n  document.getElementById('wdgt_mtnHeader').addEventListener('click', toggleMTN);\r\n  document.getElementById('wdgt_bankSubmit').addEventListener('click', validateBank);\r\n  document.getElementById('wdgt_mtnWithdraw').addEventListener('click', validateMTN);\r\n  document.getElementById('wdgt_payNow').addEventListener('click', closeOverlay);\r\n  document.getElementById('wdgt_closeBtn').addEventListener('click', closeOverlay);\r\n  \r\n  \/\/ Initialize animations\r\n  applyAnimations();\r\n})();\r\n<\/script>\r\n",
