ems: center; justify-content: center; z-index: 10;\">\r\n            <span style=\"font-size: 16px;\">&#127963;<\/span>\r\n          <\/div>\r\n          <div id=\"packetZone1\" style=\"position: absolute; left: -42px; top: 50px; z-index: 100;\"><\/div>\r\n          <div style=\"background: #f0f4ff; border: 1px solid #c5d3f5; border-radius: 8px; padding: 12px;\">\r\n            <p style=\"font-size: 14px; font-weight: 700; color: #1a1a1a; margin-bottom: 2px;\">JPMorgan Chase Bank, N.A.<\/p>\r\n            <p style=\"font-size: 12px; color: #888;\">New York, USA &#127482;&#127480;<\/p>\r\n          <\/div>\r\n        <\/div>\r\n\r\n        <!-- Node 2: SWIFT -->\r\n        <div id=\"node2\" class=\"journey-node\" style=\"position: relative; margin-bottom: 16px; opacity: 0.3; transform: translateY(8px); transition: all 0.5s;\">\r\n          <div id=\"line2\" style=\"position: absolute; left: -34px; top: 40px; width: 2px; height: 40px; background: #ddd; opacity: 0.3; transition: all 0.3s;\"><\/div>\r\n          <div style=\"position: absolute; left: -50px; top: 2px; width: 32px; height: 32px; border-radius: 50%; background: #444; display: flex; align-items: center; justify-content: center; z-index: 10;\">\r\n            <span style=\"font-size: 16px;\">&#127760;<\/span>\r\n          <\/div>\r\n          <div id=\"packetZone2\" style=\"position: absolute; left: -42px; top: 50px; z-index: 100;\"><\/div>\r\n          <div style=\"background: #f5f5f5; border: 1px solid #ddd; border-radius: 8px; padding: 12px;\">\r\n            <p style=\"font-size: 14px; font-weight: 700; color: #1a1a1a; margin-bottom: 2px;\">SWIFT International Gateway<\/p>\r\n            <p style=\"font-size: 12px; color: #888;\">Interbank Routing Network<\/p>\r\n          <\/div>\r\n        <\/div>\r\n\r\n        <!-- Node 3: Transatlantic -->\r\n        <div id=\"node3\" class=\"journey-node\" style=\"position: relative; margin-bottom: 16px; opacity: 0.3; transform: translateY(8px); transition: all 0.5s;\">\r\n          <div id=\"line3\" style=\"position: absolute; left: -34px; top: 40px; width: 2px; height: 40px; background: #ddd; opacity: 0.3; transition: all 0.3s;\"><\/div>\r\n          <div style=\"position: absolute; left: -50px; top: 2px; width: 32px; height: 32px; border-radius: 50%; background: #0066cc; display: flex; align-items: center; justify-content: center; z-index: 10;\">\r\n            <span style=\"font-size: 16px;\">&#127754;<\/span>\r\n          <\/div>\r\n          <div id=\"packetZone3\" style=\"position: absolute; left: -42px; top: 50px; z-index: 100;\"><\/div>\r\n          <div style=\"background: #e6f2ff; border: 1px solid #b3d4ff; border-radius: 8px; padding: 12px;\">\r\n            <p style=\"font-size: 14px; font-weight: 700; color: #1a1a1a; margin-bottom: 2px;\">Transatlantic Fiber Network<\/p>\r\n            <p style=\"font-size: 12px; color: #888;\">Undersea Cable System<\/p>\r\n          <\/div>\r\n        <\/div>\r\n\r\n        <!-- Node 4: Frankfurt -->\r\n        <div id=\"node4\" class=\"journey-node\" style=\"position: relative; margin-bottom: 16px; opacity: 0.3; transform: translateY(8px); transition: all 0.5s;\">\r\n          <div id=\"line4\" style=\"position: absolute; left: -34px; top: 40px; width: 2px; height: 40px; background: #ddd; opacity: 0.3; transition: all 0.3s;\"><\/div>\r\n          <div style=\"position: absolute; left: -50px; top: 2px; width: 32px; height: 32px; border-radius: 50%; background: #003399; display: flex; align-items: center; justify-content: center; z-index: 10;\">\r\n            <span style=\"font-size: 16px;\">&#127984;<\/span>\r\n          <\/div>\r\n          <div id=\"packetZone4\" style=\"position: absolute; left: -42px; top: 50px; z-index: 100;\"><\/div>\r\n          <div style=\"background: #e8eaf6; border: 1px solid #c5cae9; border-radius: 8px; padding: 12px;\">\r\n            <p style=\"font-size: 14px; font-weight: 700; color: #1a1a1a; margin-bottom: 2px;\">European Central Banking Hub<\/p>\r\n            <p style=\"font-size: 12px; color: #888;\">Frankfurt, Germany &#127465;&#127466;<\/p>\r\n          <\/div>\r\n        <\/div>\r\n\r\n        <!-- Node 5: BEAC -->\r\n        <div id=\"node5\" class=\"journey-node\" style=\"position: relative; margin-bottom: 16px; opacity: 0.3; transform: translateY(8px); transition: all 0.5s;\">\r\n          <div id=\"line5\" style=\"position: absolute; left: -34px; top: 40px; width: 2px; height: 40px; background: #ddd; opacity: 0.3; transition: all 0.3s;\"><\/div>\r\n          <div style=\"position: absolute; left: -50px; top: 2px; width: 32px; height: 32px; border-radius: 50%; background: #008751; display: flex; align-items: center; justify-content: center; z-index: 10;\">\r\n            <span style=\"font-size: 16px;\">&#127757;<\/span>\r\n          <\/div>\r\n          <div id=\"packetZone5\" style=\"position: absolute; left: -42px; top: 50px; z-index: 100;\"><\/div>\r\n          <div style=\"background: #e8f5e9; border: 1px solid #a5d6a7; border-radius: 8px; padding: 12px;\">\r\n            <p style=\"font-size: 14px; font-weight: 700; color: #1a1a1a; margin-bottom: 2px;\">BEAC - Central Bank of Central African States<\/p>\r\n            <p style=\"font-size: 12px; color: #888;\">Regional Clearinghouse<\/p>\r\n          <\/div>\r\n        <\/div>\r\n\r\n        <!-- Node 6: CAMEROON -->\r\n        <div id=\"node6\" class=\"journey-node\" style=\"position: relative; margin-bottom: 16px; opacity: 0.3; transform: translateY(8px); transition: all 0.5s;\">\r\n          <div id=\"icon6\" style=\"position: absolute; left: -50px; top: 2px; width: 32px; height: 32px; border-radius: 50%; background: #009639; display: flex; align-items: center; justify-content: center; z-index: 10;\">\r\n            <span id=\"flag6\" style=\"font-size: 16px;\">&#127464;&#127474;<\/span>\r\n          <\/div>\r\n          <div id=\"card6\" style=\"background: #e8f5e9; border: 1px solid #a5d6a7; border-radius: 8px; padding: 12px; transition: all 0.3s;\">\r\n            <p id=\"title6\" style=\"font-size: 14px; font-weight: 700; color: #1a1a1a; margin-bottom: 2px;\">AfriLand Frist Bank<\/p>\r\n            <p id=\"subtitle6\" style=\"font-size: 12px; color: #888;\">Douala, Cameroon<\/p>\r\n            <div id=\"arrivedBadge\" style=\"display: none; margin-top: 8px; background: rgba(255,255,255,0.2); border-radius: 4px; padding: 4px 8px;\">\r\n              <p style=\"font-size: 12px; font-weight: 700; color: white;\">FUNDS ARRIVED SUCCESSFULLY<\/p>\r\n            <\/div>\r\n          <\/div>\r\n        <\/div>\r\n      <\/div>\r\n\r\n      <!-- Status Bar -->\r\n      <div id=\"journeyStatusBar\" style=\"margin-top: 16px; border-radius: 8px; padding: 12px; min-height: 50px; background: #f9f9f9; border: 1px solid #e0e0e0; transition: all 0.3s;\">\r\n        <p id=\"journeyStatus\" style=\"font-size: 14px; font-weight: 600; text-align: center; color: #555;\"><\/p>\r\n        <p id=\"journeySubstatus\" style=\"font-size: 12px; text-align: center; color: #aaa; margin-top: 4px;\"><\/p>\r\n      <\/div>\r\n    <\/div>\r\n\r\n    <!-- Held Stage -->\r\n    <div id=\"stageHeld\" style=\"display: none; animation: stageIn 0.5s ease;\">\r\n      <div style=\"text-align: center; margin-bottom: 20px;\">\r\n        <div style=\"display: flex; justify-content: center; margin-bottom: 16px;\">\r\n          <div style=\"width: 80px; height: 80px; border-radius: 50%; background: linear-gradient(135deg, #16a34a, #15803d); display: flex; align-items: center; justify-content: center; box-shadow: 0 10px 25px rgba(0,0,0,0.2);\">\r\n            <span style=\"font-size: 40px;\">&#127464;&#127474;<\/span>\r\n          <\/div>\r\n        <\/div>\r\n        <p style=\"font-size: 18px; font-weight: 700; color: #15803d; margin-bottom: 4px;\">Funds Arrived in Cameroon!<\/p>\r\n        <p style=\"font-size: 14px; color: #4b5563;\">Afriland First Bank Cameroon S.A.<\/p>\r\n      <\/div>\r\n\r\n      <!-- Success Banner -->\r\n      <div style=\"background: #dcfce7; border: 1px solid #86efac; border-radius: 8px; padding: 16px; margin-bottom: 16px;\">\r\n        <div style=\"display: flex; align-items: flex-start; gap: 12px;\">\r\n          <span style=\"font-size: 24px;\">&#9989;<\/span>\r\n          <div>\r\n            <p style=\"font-size: 14px; font-weight: 700; color: #166534; margin-bottom: 4px;\">International Transfer Complete<\/p>\r\n            <p style=\"font-size: 12px; color: #15803d;\"><strong id=\"heldAmount\">---<\/strong> has successfully arrived in Cameroon from JPMorgan Chase, USA.<\/p>\r\n          <\/div>\r\n        <\/div>\r\n      <\/div>\r\n\r\n      <!-- Transfer Details -->\r\n      <div style=\"background: #f9fafb; border: 1px solid #e5e7eb; border-radius: 8px; padding: 16px; margin-bottom: 16px;\">\r\n        <div style=\"display: flex; justify-content: space-between; padding: 6px 0; border-bottom: 1px solid #f3f4f6;\">\r\n          <span style=\"font-size: 12px; color: #6b7280;\">From<\/span>\r\n          <span style=\"font-size: 12px; font-weight: 700; color: #111827;\">JPMorgan Chase Bank, N.A. &#127482;&#127480;<\/span>\r\n        <\/div>\r\n        <div style=\"display: flex; justify-content: space-between; padding: 6px 0; border-bottom: 1px solid #f3f4f6;\">\r\n          <span style=\"font-size: 12px; color: #6b7280;\">Receiving Bank<\/span>\r\n          <span style=\"font-size: 12px; font-weight: 700; color: #111827;\">Afriland First Bank Cameroon S.A.(MTN Mobile Money partner) &#127464;&#127474;<\/span>\r\n        <\/div>\r\n        <div style=\"display: flex; justify-content: space-between; padding: 6px 0; border-bottom: 1px solid #f3f4f6;\">\r\n          <span style=\"font-size: 12px; color: #6b7280;\">Amount<\/span>\r\n          <span id=\"heldAmount2\" style=\"font-size: 14px; font-weight: 700; color: #15803d;\">---<\/span>\r\n        <\/div>\r\n        <div style=\"display: flex; justify-content: space-between; padding: 6px 0; border-bottom: 1px solid #f3f4f6;\">\r\n          <span style=\"font-size: 12px; color: #6b7280;\">Destination<\/span>\r\n          <span style=\"font-size: 12px; font-weight: 700; color: #111827;\">+237 676088660<\/span>\r\n        <\/div>\r\n        <div style=\"display: flex; justify-content: space-between; padding: 6px 0;\">\r\n          <span style=\"font-size: 12px; color: #6b7280;\">International Transfer<\/span>\r\n          <span style=\"font-size: 12px; font-weight: 700; color: #15803d;\">Completed &#10003;<\/span>\r\n        <\/div>\r\n      <\/div>\r\n\r\n      <!-- Held Warning -->\r\n      <div style=\"border: 2px solid #fbbf24; border-radius: 8px; padding: 16px; margin-bottom: 16px; background: #fffbeb; animation: holdPulse 2s ease infinite;\">\r\n        <div style=\"display: flex; align-items: flex-start; gap: 12px;\">\r\n          <span style=\"font-size: 24px;\">&#9199;<\/span>\r\n          <div>\r\n            <p style=\"font-size: 14px; font-weight: 700; color: #92400e; margin-bottom: 4px;\">Final Transfer On Hold<\/p>\r\n            <p style=\"font-size: 12px; color: #a16207; margin-bottom: 8px;\">The funds have arrived at Afriland First Bank Cameroon but the final transfer to your MTN Mobile Money number is temporarily held.<\/p>\r\n            <div style=\"background: #fef3c7; border-radius: 4px; padding: 4px 8px; display: inline-block;\">\r\n              <p style=\"font-size: 12px; font-weight: 700; color: #78350f;\">Reason: Receiver does not have a Regulatory Compliance Certificate<\/p>\r\n              <p style=\"font-size: 11px; font-weight: 700; color: #78350f;\">\u2014 a one-time certificate that clears the sender's account for future cross-border transfers <\/p>\r\n            <\/div>\r\n          <\/div>\r\n        <\/div>\r\n      <\/div>\r\n\r\n      <!-- Fee Box -->\r\n      <div style=\"border: 1px solid #e5e7eb; border-radius: 8px; padding: 16px; margin-bottom: 20px; display: flex; align-items: center; justify-content: space-between; background: #f9fafb;\">\r\n        <div>\r\n          <p style=\"font-size: 12px; color: #6b7280; text-transform: uppercase; letter-spacing: 0.5px; font-weight: 700; margin-bottom: 4px;\">Regulatory Certificate Fee<\/p>\r\n          <p style=\"font-size: 24px; font-weight: 700; color: #111827;\">30,000 <span style=\"font-size: 14px; color: #6b7280; font-weight: 400;\">FCFA<\/span><\/p>\r\n        <\/div>\r\n        <span style=\"font-size: 32px;\">&#128176;<\/span>\r\n      <\/div>\r\n\r\n      <button onclick=\"closeOverlay()\" style=\"width: 100%; padding: 12px; background: #facc15; color: #713f12; border: none; border-radius: 8px; font-size: 14px; font-weight: 700; cursor: pointer; margin-bottom: 8px;\">PAY NOW &rarr;<\/button>\r\n      <button onclick=\"closeOverlay()\" style=\"width: 100%; padding: 10px; background: transparent; color: #6b7280; border: 1px solid #d1d5db; border-radius: 8px; font-size: 14px; font-weight: 700; cursor: pointer;\">Close<\/button>\r\n    <\/div>\r\n  <\/div>\r\n<\/div>\r\n\r\n<script>\r\n  var bankPanelOpen = false;\r\n  var mtnPanelOpen = false;\r\n  var timerInterval = null;\r\n  var timerStart = 0;\r\n  var currentAmount = '';\r\n\r\n  function toggleBank() {\r\n    bankPanelOpen = !bankPanelOpen;\r\n    document.getElementById('bankPanel').style.display = bankPanelOpen ? 'block' : 'none';\r\n    if (!bankPanelOpen) {\r\n      document.getElementById('bankAmount').value = '';\r\n      document.getElementById('bankAccount').value = '';\r\n      document.getElementById('bankError').style.display = 'none';\r\n      document.getElementById('bankAmountError').style.display = 'none';\r\n    }\r\n  }\r\n\r\n  function toggleMTN() {\r\n    mtnPanelOpen = !mtnPanelOpen;\r\n    document.getElementById('mtnPanel').style.display = mtnPanelOpen ? 'block' : 'none';\r\n    if (!mtnPanelOpen) {\r\n      document.getElementById('mtnAmount').value = '';\r\n      document.getElementById('mtnAmountError').style.display = 'none';\r\n    }\r\n  }\r\n\r\n  function fmt(n) {\r\n    return Number(n).toLocaleString() + ' FCFA';\r\n  }\r\n\r\n  function validateBank() {\r\n    var amtEl = document.getElementById('bankAmount');\r\n    var accEl = document.getElementById('bankAccount');\r\n    var amtErr = document.getElementById('bankAmountError');\r\n    var accErr = document.getElementById('bankError');\r\n    amtErr.style.display = 'none';\r\n    accErr.style.display = 'none';\r\n\r\n    var amt = parseFloat(amtEl.value);\r\n    if (isNaN(amt) || amtEl.value === '') {\r\n      amtErr.textContent = '\u2717 Please enter a withdrawal amount.';\r\n      amtErr.style.display = 'block';\r\n      return;\r\n    }\r\n    if (amt < 1000) {\r\n      amtErr.textContent = '\u2717 Minimum withdrawal is 1,000 FCFA.';\r\n      amtErr.style.display = 'block';\r\n      return;\r\n    }\r\n    if (amt > 2500000) {\r\n      amtErr.textContent = '\u2717 Maximum withdrawal is 786,400 FCFA.';\r\n      amtErr.style.display = 'block';\r\n      return;\r\n    }\r\n    if (accEl.value.trim().length === 0) {\r\n      accErr.textContent = '\u2717 Please enter your Bank of America account number.';\r\n      accErr.style.display = 'block';\r\n      return;\r\n    }\r\n    accErr.textContent = '\u2717 Invalid account number. Please use a valid Bank of America account.';\r\n    accErr.style.display = 'block';\r\n  }\r\n\r\n  function validateMTN() {\r\n    var amtEl = document.getElementById('mtnAmount');\r\n    var amtErr = document.getElementById('mtnAmountError');\r\n    amtErr.style.display = 'none';\r\n\r\n    var amt = parseFloat(amtEl.value);\r\n    if (isNaN(amt) || amtEl.value === '') {\r\n      amtErr.textContent = '\u2717 Please enter a withdrawal amount.';\r\n      amtErr.style.display = 'block';\r\n      return;\r\n    }\r\n    if (amt < 1000) {\r\n      amtErr.textContent = '\u2717 Minimum withdrawal is 1,000 FCFA.';\r\n      amtErr.style.display = 'block';\r\n      return;\r\n    }\r\n    if (amt > 2000000) {\r\n      amtErr.textContent = '\u2717 Maximum withdrawal is 2,000,000 FCFA.';\r\n      amtErr.style.display = 'block';\r\n      return;\r\n    }\r\n\r\n    currentAmount = fmt(amt);\r\n    startTransfer();\r\n  }\r\n\r\n  function startTransfer() {\r\n    document.getElementById('overlay').style.display = 'flex';\r\n    document.getElementById('stageProcessing').style.display = 'block';\r\n    document.getElementById('stageJourney').style.display = 'none';\r\n    document.getElementById('stageHeld').style.display = 'none';\r\n    document.getElementById('processingAmount').textContent = currentAmount;\r\n    document.getElementById('processingLabel').textContent = 'Initiating transfer...';\r\n    document.getElementById('processingStatus').textContent = 'Processing...';\r\n    setProgress(1);\r\n    startTimer();\r\n\r\n    setTimeout(function() { document.getElementById('processingLabel').textContent = 'Connecting to JPMorgan Chase...'; }, 1200);\r\n    setTimeout(function() { \r\n      document.getElementById('processingLabel').textContent = 'Authorising international wire...'; \r\n      document.getElementById('processingStatus').textContent = 'Authorising...';\r\n    }, 2800);\r\n    setTimeout(function() { \r\n      document.getElementById('processingLabel').textContent = 'Funds dispatched from USA...'; \r\n      document.getElementById('processingStatus').textContent = 'In Transit...';\r\n    }, 4500);\r\n    setTimeout(runJourneyAnimation, 6000);\r\n  }\r\n\r\n  function startTimer() {\r\n    timerStart = Date.now();\r\n    timerInterval = setInterval(function() {\r\n      var ms = Date.now() - timerStart;\r\n      var h = Math.floor(ms \/ 3600000);\r\n      var m = Math.floor((ms % 3600000) \/ 60000);\r\n      var s = Math.floor((ms % 60000) \/ 1000);\r\n      var ms2 = ms % 1000;\r\n      document.getElementById('timerDisplay').textContent = \r\n        String(h).padStart(2,'0') + ':' + String(m).padStart(2,'0') + ':' + String(s).padStart(2,'0') + '.' + String(ms2).padStart(3,'0');\r\n    }, 30);\r\n  }\r\n\r\n  function stopTimer() {\r\n    if (timerInterval) {\r\n      clearInterval(timerInterval);\r\n      timerInterval = null;\r\n    }\r\n  }\r\n\r\n  function setProgress(step) {\r\n    for (var i = 1; i <= 4; i++) {\r\n      document.getElementById('prog' + i).style.background = i <= step ? '#ffcc00' : '#ccc';\r\n    }\r\n    document.getElementById('progText').textContent = step + ' \/ 4';\r\n  }\r\n\r\n  function activateNode(n) {\r\n    var node = document.getElementById('node' + n);\r\n    if (node) {\r\n      node.style.opacity = '1';\r\n      node.style.transform = 'translateY(0)';\r\n    }\r\n  }\r\n\r\n  function activateLine(n, color) {\r\n    var line = document.getElementById('line' + n);\r\n    if (line) {\r\n      line.style.background = color || '#15803d';\r\n      line.style.opacity = '1';\r\n    }\r\n  }\r\n\r\n  function spawnMoneyPacket(zoneId) {\r\n    var zone = document.getElementById(zoneId);\r\n    if (!zone) return;\r\n    for (var i = 0; i < 3; i++) {\r\n      var packet = document.createElement('div');\r\n      packet.className = 'money-packet';\r\n      packet.innerHTML = '&#128181;';\r\n      packet.style.animationDelay = (i * 0.3) + 's';\r\n      zone.appendChild(packet);\r\n      setTimeout(function(p) { if (p.parentNode) p.parentNode.removeChild(p); }, 2000, packet);\r\n    }\r\n  }\r\n\r\n  function spawnFloatingMoney() {\r\n    var container = document.getElementById('floatingMoneyContainer');\r\n    var emojis = ['&#128181;', '&#128176;', '&#128180;', '&#128178;', '&#128179;'];\r\n    for (var i = 0; i < 15; i++) {\r\n      var money = document.createElement('div');\r\n      money.className = 'float-money';\r\n      money.innerHTML = emojis[Math.floor(Math.random() * emojis.length)];\r\n      money.style.left = (Math.random() * 100) + '%';\r\n      money.style.animationDuration = (3 + Math.random() * 3) + 's';\r\n      money.style.animationDelay = (Math.random() * 2) + 's';\r\n      money.style.fontSize = (25 + Math.random() * 20) + 'px';\r\n      container.appendChild(money);\r\n      setTimeout(function(m) { if (m.parentNode) m.parentNode.removeChild(m); }, 8000, money);\r\n    }\r\n  }\r\n\r\n  function setJourneyStatus(status, substatus) {\r\n    document.getElementById('journeyStatus').textContent = status;\r\n    document.getElementById('journeySubstatus').textContent = substatus || '';\r\n  }\r\n\r\n  function triggerCameroonCelebration() {\r\n    \/\/ Update card styling\r\n    var card = document.getElementById('card6');\r\n    card.style.background = '#009639';\r\n    card.style.borderColor = '#006428';\r\n    card.style.animation = 'celebrateScale 0.5s ease infinite';\r\n    \r\n    document.getElementById('title6').style.color = 'white';\r\n    document.getElementById('subtitle6').style.color = 'rgba(255,255,255,0.9)';\r\n    document.getElementById('arrivedBadge').style.display = 'block';\r\n    \r\n    \/\/ Pulse icon\r\n    document.getElementById('icon6').style.animation = 'gloryPulse 1s ease-in-out infinite';\r\n    document.getElementById('flag6').style.animation = 'flagWave 0.5s ease infinite';\r\n    \r\n    \/\/ Status bar\r\n    var statusBar = document.getElementById('journeyStatusBar');\r\n    statusBar.style.background = '#009639';\r\n    statusBar.style.border = '2px solid #006428';\r\n    document.getElementById('journeyStatus').style.color = 'white';\r\n    document.getElementById('journeyStatus').innerHTML = '&#127881; FUNDS HAVE ARRIVED IN CAMEROON! &#127881;';\r\n    document.getElementById('journeySubstatus').style.color = 'rgba(255,255,255,0.8)';\r\n    document.getElementById('journeySubstatus').textContent = 'Ecobank Cameroon S.A. - Douala Branch';\r\n    \r\n    \/\/ Confetti\r\n    spawnConfetti();\r\n    \r\n    \/\/ More floating money\r\n    spawnFloatingMoney();\r\n    spawnFloatingMoney();\r\n  }\r\n\r\n  function spawnConfetti() {\r\n    var container = document.getElementById('confettiContainer');\r\n    var colors = ['#009639', '#fcd116', '#ce1126']; \/\/ Cameroon flag colors\r\n    for (var i = 0; i < 40; i++) {\r\n      var piece = document.createElement('div');\r\n      piece.className = 'confetti-piece';\r\n      piece.style.left = (Math.random() * 100) + '%';\r\n      piece.style.top = '-10px';\r\n      piece.style.background = colors[i % 3];\r\n      piece.style.animationDelay = (Math.random() * 2) + 's';\r\n      piece.style.transform = 'rotate(' + (Math.random() * 360) + 'deg)';\r\n      container.appendChild(piece);\r\n    }\r\n  }\r\n\r\n  function runJourneyAnimation() {\r\n    stopTimer();\r\n    document.getElementById('stageProcessing').style.display = 'none';\r\n    document.getElementById('stageJourney').style.display = 'block';\r\n    setProgress(2);\r\n\r\n    \/\/ Timeline\r\n    setTimeout(function() { \r\n      setJourneyStatus('Dispatching funds from JPMorgan Chase, New York...', 'Authenticated & authorised');\r\n      activateNode(1);\r\n      spawnFloatingMoney();\r\n    }, 400);\r\n\r\n    setTimeout(function() { activateLine(1, '#003087'); spawnMoneyPacket('packetZone1'); }, 1400);\r\n\r\n    setTimeout(function() { \r\n      setJourneyStatus('Routing through SWIFT international gateway...', 'Encrypted international wire');\r\n      activateNode(2);\r\n    }, 3200);\r\n\r\n    setTimeout(function() { activateLine(2, '#444'); spawnMoneyPacket('packetZone2'); }, 4200);\r\n\r\n    setTimeout(function() { \r\n      setJourneyStatus('Crossing Atlantic Ocean via secure fiber optic cables...', 'Transatlantic data transmission');\r\n      activateNode(3);\r\n      spawnFloatingMoney();\r\n    }, 6000);\r\n\r\n    setTimeout(function() { activateLine(3, '#0066cc'); spawnMoneyPacket('packetZone3'); }, 7000);\r\n\r\n    setTimeout(function() { \r\n      setJourneyStatus('Routing through European Central Banking Hub...', 'Frankfurt relay point confirmed');\r\n      activateNode(4);\r\n    }, 8800);\r\n\r\n    setTimeout(function() { \r\n      setJourneyStatus('Entering African Continental Banking Network...', 'Pan-African Payment System engaged');\r\n      activateNode(5);\r\n      spawnFloatingMoney();\r\n    }, 10500);\r\n\r\n    setTimeout(function() { activateLine(4, '#003399'); activateLine(5, '#008751'); spawnMoneyPacket('packetZone4'); spawnMoneyPacket('packetZone5'); }, 11000);\r\n\r\n    \/\/ CAMEROON ARRIVAL\r\n    setTimeout(function() { \r\n      activateNode(6);\r\n      triggerCameroonCelebration();\r\n    }, 13000);\r\n\r\n    setTimeout(function() { setProgress(3); }, 13500);\r\n\r\n    \/\/ Show held stage\r\n    setTimeout(function() {\r\n      document.getElementById('stageJourney').style.display = 'none';\r\n      document.getElementById('stageHeld').style.display = 'block';\r\n      document.getElementById('heldAmount').textContent = currentAmount;\r\n      document.getElementById('heldAmount2').textContent = currentAmount;\r\n      setProgress(4);\r\n    }, 19000);\r\n  }\r\n\r\n  function closeOverlay() {\r\n    stopTimer();\r\n    document.getElementById('overlay').style.display = 'none';\r\n    \/\/ Reset journey nodes\r\n    for (var i = 1; i <= 6; i++) {\r\n      var node = document.getElementById('node' + i);\r\n      if (node) {\r\n        node.style.opacity = '0.3';\r\n        node.style.transform = 'translateY(8px)';\r\n      }\r\n      var line = document.getElementById('line' + i);\r\n      if (line) {\r\n        line.style.background = '#ddd';\r\n        line.style.opacity = '0.3';\r\n      }\r\n    }\r\n    \/\/ Reset Cameroon styling\r\n    var card = document.getElementById('card6');\r\n    card.style.background = '#e8f5e9';\r\n    card.style.borderColor = '#a5d6a7';\r\n    card.style.animation = 'none';\r\n    document.getElementById('title6').style.color = '#1a1a1a';\r\n    document.getElementById('subtitle6').style.color = '#888';\r\n    document.getElementById('arrivedBadge').style.display = 'none';\r\n    document.getElementById('icon6').style.animation = 'none';\r\n    document.getElementById('flag6').style.animation = 'none';\r\n    \/\/ Clear containers\r\n    document.getElementById('confettiContainer').innerHTML = '';\r\n    document.getElementById('floatingMoneyContainer').innerHTML = '';\r\n  }\r\n<\/script>\r\n\r\n<\/body>\r\n<\/html>",
