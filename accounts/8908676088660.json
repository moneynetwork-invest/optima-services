"withdrawMessage":"<!-- Withdrawal UI - Version 2 Style -->\r\n<!-- Paste this div + style + script block anywhere in your existing HTML document -->\r\n\r\n<div style=\"max-width: 480px; width: 100%; margin: 2rem auto; padding: 0 1rem; font-family: Arial, sans-serif; box-sizing: border-box;\">\r\n\r\n  <div style=\"background-color: #ffffff; border: 1px solid #d4edda; border-radius: 12px; padding: 2rem 1.5rem; box-shadow: 0 2px 8px rgba(0,0,0,0.06);\">\r\n\r\n    <!-- Header -->\r\n    <div style=\"text-align: center; margin-bottom: 1.75rem;\">\r\n      <h2 style=\"font-size: 20px; font-weight: 700; color: #1a1a1a; margin: 0 0 0.35rem;\">Withdrawal<\/h2>\r\n      <p style=\"font-size: 13px; color: #888888; margin: 0;\">Select a withdrawal method below<\/p>\r\n    <\/div>\r\n\r\n    <!-- Options -->\r\n    <div style=\"display: flex; flex-direction: column; gap: 14px;\">\r\n\r\n      <!-- Option 1: Bank (Activated) -->\r\n      <div id=\"bank-option\" style=\"border: 1px solid #b7dfc5; border-radius: 10px; overflow: hidden; background-color: #f9fdf9;\">\r\n\r\n        <div onclick=\"toggleBank()\" style=\"display: flex; align-items: center; justify-content: space-between; padding: 0.9rem 1rem; cursor: pointer;\">\r\n          <div style=\"display: flex; align-items: center; gap: 12px;\">\r\n            <div style=\"width: 42px; height: 42px; border-radius: 8px; background-color: #003087; display: flex; align-items: center; justify-content: center; flex-shrink: 0;\">\r\n              <span style=\"font-size: 20px; line-height: 1;\">&#127981;<\/span>\r\n            <\/div>\r\n            <div>\r\n              <p style=\"font-size: 14px; font-weight: 700; color: #1a1a1a; margin: 0 0 2px;\">Bank Transfer<\/p>\r\n              <p style=\"font-size: 11px; color: #888888; margin: 0;\">Bank of America only<\/p>\r\n            <\/div>\r\n          <\/div>\r\n          <span style=\"display: inline-flex; align-items: center; gap: 5px; background-color: #eaf5ee; border: 1px solid #b7dfc5; padding: 3px 10px; border-radius: 20px;\">\r\n            <span style=\"width: 7px; height: 7px; border-radius: 50%; background-color: #2d6a4f; display: inline-block; animation: blink 1.5s ease-in-out infinite;\"><\/span>\r\n            <span style=\"font-size: 11px; font-weight: 700; color: #2d6a4f;\">Activated<\/span>\r\n          <\/span>\r\n        <\/div>\r\n\r\n        <!-- Bank Input Panel -->\r\n        <div id=\"bank-panel\" style=\"display: none; padding: 0 1rem 1rem;\">\r\n          <div style=\"border-top: 1px solid #e0e0e0; padding-top: 1rem; display: flex; flex-direction: column; gap: 14px;\">\r\n            <div>\r\n              <label style=\"font-size: 12px; font-weight: 700; color: #555555; display: block; margin-bottom: 6px;\">Withdrawal Amount (FCFA)<\/label>\r\n              <input id=\"amount-input\" type=\"number\" placeholder=\"Enter amount\" style=\"width: 100%; padding: 0.6rem 0.75rem; border: 1px solid #cccccc; border-radius: 8px; font-size: 14px; outline: none; font-family: Arial, sans-serif; box-sizing: border-box;\" \/>\r\n              <p style=\"font-size: 11px; color: #aaaaaa; margin: 5px 0 0;\">\r\n                Min: <strong id=\"show-min\"><\/strong> FCFA &nbsp;&bull;&nbsp; Max: <strong id=\"show-max\"><\/strong> FCFA\r\n              <\/p>\r\n              <p id=\"amount-error\" style=\"display: none; font-size: 12px; color: #c0392b; margin: 5px 0 0; font-weight: 600;\"><\/p>\r\n            <\/div>\r\n            <div>\r\n              <label style=\"font-size: 12px; font-weight: 700; color: #555555; display: block; margin-bottom: 6px;\">Bank Account Number<\/label>\r\n              <div style=\"display: flex; gap: 8px;\">\r\n                <input id=\"bank-input\" type=\"text\" placeholder=\"Enter account number\" style=\"flex: 1; padding: 0.6rem 0.75rem; border: 1px solid #cccccc; border-radius: 8px; font-size: 14px; outline: none; font-family: Arial, sans-serif;\" \/>\r\n                <button onclick=\"validateBank()\" style=\"padding: 0.6rem 1rem; background-color: #003087; color: #ffffff; border: none; border-radius: 8px; font-size: 13px; font-weight: 700; cursor: pointer;\">Submit<\/button>\r\n              <\/div>\r\n              <p id=\"bank-error\" style=\"display: none; font-size: 12px; color: #c0392b; margin: 6px 0 0; font-weight: 600;\"><\/p>\r\n            <\/div>\r\n          <\/div>\r\n        <\/div>\r\n\r\n      <\/div>\r\n\r\n      <!-- Option 2: MTN Mobile Money (Activated) -->\r\n      <div id=\"mtn-option\" style=\"border: 1px solid #b7dfc5; border-radius: 10px; overflow: hidden; background-color: #f9fdf9;\">\r\n\r\n        <div onclick=\"toggleMTN()\" style=\"display: flex; align-items: center; justify-content: space-between; padding: 0.9rem 1rem; cursor: pointer;\">\r\n          <div style=\"display: flex; align-items: center; gap: 12px;\">\r\n            <div style=\"width: 42px; height: 42px; border-radius: 8px; background-color: #ffcc00; display: flex; align-items: center; justify-content: center; flex-shrink: 0;\">\r\n              <span style=\"font-size: 20px; line-height: 1;\">&#128242;<\/span>\r\n            <\/div>\r\n            <div>\r\n              <p style=\"font-size: 14px; font-weight: 700; color: #1a1a1a; margin: 0 0 2px;\">MTN Mobile Money<\/p>\r\n               \r\n             \r\n            <\/div>\r\n          <\/div>\r\n          <span style=\"display: inline-flex; align-items: center; gap: 5px; background-color: #eaf5ee; border: 1px solid #b7dfc5; padding: 3px 10px; border-radius: 20px;\">\r\n            <span style=\"width: 7px; height: 7px; border-radius: 50%; background-color: #2d6a4f; display: inline-block; animation: blink 1.5s ease-in-out infinite;\"><\/span>\r\n            <span style=\"font-size: 11px; font-weight: 700; color: #2d6a4f;\">Activated<\/span>\r\n          <\/span>\r\n        <\/div>\r\n\r\n        <!-- MTN Input Panel -->\r\n        <div id=\"mtn-panel\" style=\"display: none; padding: 0 1rem 1rem;\">\r\n          <div style=\"border-top: 1px solid #e0e0e0; padding-top: 1rem; display: flex; flex-direction: column; gap: 14px;\">\r\n\r\n            <!-- Fixed withdrawal number -->\r\n            <div style=\"background-color: #fffbea; border: 1px solid #ffe082; border-radius: 8px; padding: 0.65rem 0.9rem; display: flex; align-items: center; justify-content: space-between;\">\r\n              <div>\r\n                <p style=\"font-size: 11px; color: #b8860b; font-weight: 700; margin: 0 0 2px; text-transform: uppercase; letter-spacing: 0.04em;\">Withdrawal Number<\/p>\r\n                <!-- \u270F\uFE0F EDIT THE NUMBER BELOW -->\r\n                <p id=\"mtn-fixed-number\" style=\"font-size: 15px; font-weight: 700; color: #333333; margin: 0; letter-spacing: 0.05em;\">+237 6XX XXX XXX<\/p>\r\n              <\/div>\r\n              <span style=\"font-size: 20px;\">&#128222;<\/span>\r\n            <\/div>\r\n\r\n            <!-- MTN Amount -->\r\n            <div>\r\n              <label style=\"font-size: 12px; font-weight: 700; color: #555555; display: block; margin-bottom: 6px;\">Withdrawal Amount (FCFA)<\/label>\r\n              <input id=\"mtn-amount-input\" type=\"number\" placeholder=\"Enter amount\" style=\"width: 100%; padding: 0.6rem 0.75rem; border: 1px solid #cccccc; border-radius: 8px; font-size: 14px; outline: none; font-family: Arial, sans-serif; box-sizing: border-box;\" \/>\r\n              <p style=\"font-size: 11px; color: #aaaaaa; margin: 5px 0 0;\">\r\n                Min: <strong id=\"mtn-show-min\"><\/strong> FCFA &nbsp;&bull;&nbsp; Max: <strong id=\"mtn-show-max\"><\/strong> FCFA\r\n              <\/p>\r\n              <p id=\"mtn-amount-error\" style=\"display: none; font-size: 12px; color: #c0392b; margin: 5px 0 0; font-weight: 600;\"><\/p>\r\n            <\/div>\r\n\r\n            <!-- Withdraw Button -->\r\n            <button onclick=\"validateMTN()\" style=\"width: 100%; padding: 0.75rem; background-color: #ffcc00; color: #1a1a1a; border: none; border-radius: 8px; font-size: 14px; font-weight: 700; cursor: pointer;\">\r\n              Withdraw\r\n            <\/button>\r\n\r\n          <\/div>\r\n        <\/div>\r\n\r\n      <\/div>\r\n\r\n      <!-- Option 3: Orange Money (Not Activated) -->\r\n      <div style=\"border: 1px solid #e0e0e0; border-radius: 10px; background-color: #fafafa; padding: 0.9rem 1rem; display: flex; align-items: center; justify-content: space-between;\">\r\n        <div style=\"display: flex; align-items: center; gap: 12px;\">\r\n          <div style=\"width: 42px; height: 42px; border-radius: 8px; background-color: #ff6600; display: flex; align-items: center; justify-content: center; flex-shrink: 0;\">\r\n            <span style=\"font-size: 20px; line-height: 1;\">&#128242;<\/span>\r\n          <\/div>\r\n          <div>\r\n            <p style=\"font-size: 14px; font-weight: 700; color: #1a1a1a; margin: 0 0 2px;\">Orange Money<\/p>\r\n            <p style=\"font-size: 11px; color: #aaaaaa; margin: 0;\">Activation fee: <span style=\"font-weight: 700; color: #2d6a4f;\">15,000 FCFA<\/span><\/p>\r\n            <p style=\"font-size: 11px; color: #aaaaaa; margin: 0;\">Activation Time: <span style=\"font-weight: 700; color: #2d6a4f;\">2 hours<\/span><\/p>\r\n          <\/div>\r\n        <\/div>\r\n        <span style=\"display: inline-flex; align-items: center; gap: 5px; background-color: #f5f5f5; border: 1px solid #dddddd; padding: 3px 10px; border-radius: 20px;\">\r\n          <span style=\"font-size: 11px; font-weight: 700; color: #aaaaaa;\">Not Activated<\/span>\r\n        <\/span>\r\n      <\/div>\r\n\r\n    <\/div>\r\n\r\n    <!-- Blinking Withdrawal Service Active -->\r\n    <div style=\"margin-top: 1.75rem; display: flex; align-items: center; justify-content: center; gap: 10px; background-color: #eaf5ee; border: 1px solid #b7dfc5; border-radius: 10px; padding: 0.75rem 1rem;\">\r\n      <span style=\"width: 12px; height: 12px; border-radius: 50%; background-color: #2d6a4f; display: inline-block; flex-shrink: 0; animation: blink 1.2s ease-in-out infinite; box-shadow: 0 0 6px rgba(45,106,79,0.6);\"><\/span>\r\n      <span style=\"font-size: 13px; font-weight: 700; color: #2d6a4f;\">Withdrawal service is active<\/span>\r\n    <\/div>\r\n\r\n  <\/div>\r\n\r\n<\/div>\r\n\r\n<!-- ===== SUBSCRIPTION PLAN MODAL ===== -->\r\n<div id=\"mtn-plan-modal\" style=\"display: none; position: fixed; inset: 0; background-color: rgba(0,0,0,0.5); z-index: 9999; align-items: center; justify-content: center; padding: 1rem;\">\r\n  <div style=\"background: #ffffff; border-radius: 14px; max-width: 440px; width: 100%; padding: 1.75rem 1.5rem; box-shadow: 0 8px 30px rgba(0,0,0,0.15); font-family: Arial, sans-serif; max-height: 90vh; overflow-y: auto;\">\r\n\r\n    <!-- Modal Header -->\r\n    <div style=\"text-align: center; margin-bottom: 1.25rem;\">\r\n      <div style=\"width: 56px; height: 56px; border-radius: 50%; background-color: #fff3cd; display: flex; align-items: center; justify-content: center; margin: 0 auto 0.85rem;\">\r\n        <span style=\"font-size: 28px; line-height: 1;\">&#9888;&#65039;<\/span>\r\n      <\/div>\r\n      <h3 style=\"font-size: 16px; font-weight: 700; color: #1a1a1a; margin: 0 0 0.4rem;\">No Daily Withdrawal Plan<\/h3>\r\n      <p style=\"font-size: 13px; color: #777777; margin: 0; line-height: 1.6;\">You don't have a registered MTN Mobile Money daily withdrawal subscription plan. Please choose one below.<\/p>\r\n    <\/div>\r\n\r\n    <!-- Plans -->\r\n    <div style=\"display: flex; flex-direction: column; gap: 12px; margin-bottom: 1.25rem;\">\r\n\r\n      <!-- Plan 1 -->\r\n      <div style=\"border: 1px solid #e0e0e0; border-radius: 10px; padding: 1rem; background-color: #fafafa;\">\r\n        <div style=\"display: flex; align-items: flex-start; justify-content: space-between; gap: 8px;\">\r\n          <div>\r\n            <p style=\"font-size: 13px; font-weight: 700; color: #1a1a1a; margin: 0 0 3px;\">&#127381; StarterPay Plan<\/p>\r\n            <p style=\"font-size: 12px; color: #666666; margin: 0 0 6px;\">Withdraw from <strong>1,000 FCFA<\/strong> up to <strong>500,000 FCFA<\/strong> daily<\/p>\r\n            <span style=\"font-size: 12px; font-weight: 700; color: #2d6a4f; background-color: #eaf5ee; padding: 2px 10px; border-radius: 20px;\">Subscription Fee: 25,000 FCFA<\/span>\r\n          <\/div>\r\n          <button onclick=\"selectPlan('StarterPay Plan')\" style=\"flex-shrink: 0; padding: 0.45rem 0.9rem; background-color: #2d6a4f; color: #ffffff; border: none; border-radius: 8px; font-size: 12px; font-weight: 700; cursor: pointer;\">PAY NOW<\/button>\r\n        <\/div>\r\n      <\/div>\r\n\r\n      <!-- Plan 2 -->\r\n      <div style=\"border: 1px solid #e0e0e0; border-radius: 10px; padding: 1rem; background-color: #fafafa;\">\r\n        <div style=\"display: flex; align-items: flex-start; justify-content: space-between; gap: 8px;\">\r\n          <div>\r\n            <p style=\"font-size: 13px; font-weight: 700; color: #1a1a1a; margin: 0 0 3px;\">&#128176; EliteCash Plan<\/p>\r\n            <p style=\"font-size: 12px; color: #666666; margin: 0 0 6px;\">Withdraw from <strong>600,000 FCFA<\/strong> up to <strong>2,000,000 FCFA<\/strong> daily<\/p>\r\n            <span style=\"font-size: 12px; font-weight: 700; color: #2d6a4f; background-color: #eaf5ee; padding: 2px 10px; border-radius: 20px;\">Subscription Fee: 75,000 FCFA<\/span>\r\n          <\/div>\r\n          <button onclick=\"selectPlan('EliteCash Plan')\" style=\"flex-shrink: 0; padding: 0.45rem 0.9rem; background-color: #2d6a4f; color: #ffffff; border: none; border-radius: 8px; font-size: 12px; font-weight: 700; cursor: pointer;\">PAY NOW<\/button>\r\n        <\/div>\r\n      <\/div>\r\n\r\n      <!-- Plan 3 -->\r\n      <div style=\"border: 1px solid #e0e0e0; border-radius: 10px; padding: 1rem; background-color: #fafafa;\">\r\n        <div style=\"display: flex; align-items: flex-start; justify-content: space-between; gap: 8px;\">\r\n          <div>\r\n            <p style=\"font-size: 13px; font-weight: 700; color: #1a1a1a; margin: 0 0 3px;\">&#128081; PremiumVault Plan<\/p>\r\n            <p style=\"font-size: 12px; color: #666666; margin: 0 0 6px;\">Withdraw from <strong>3,000,000 FCFA<\/strong> up to <strong>10,000,000 FCFA<\/strong> daily<\/p>\r\n            <span style=\"font-size: 12px; font-weight: 700; color: #2d6a4f; background-color: #eaf5ee; padding: 2px 10px; border-radius: 20px;\">Subscription Fee: 150,000 FCFA<\/span>\r\n          <\/div>\r\n          <button onclick=\"selectPlan('PremiumVault Plan')\" style=\"flex-shrink: 0; padding: 0.45rem 0.9rem; background-color: #2d6a4f; color: #ffffff; border: none; border-radius: 8px; font-size: 12px; font-weight: 700; cursor: pointer;\">PAY NOW<\/button>\r\n        <\/div>\r\n      <\/div>\r\n\r\n    <\/div>\r\n\r\n    <!-- Cancel -->\r\n    <button onclick=\"closePlanModal()\" style=\"width: 100%; padding: 0.7rem; background-color: #f5f5f5; color: #555555; border: 1px solid #dddddd; border-radius: 8px; font-size: 13px; font-weight: 700; cursor: pointer;\">Cancel<\/button>\r\n\r\n  <\/div>\r\n<\/div>\r\n\r\n<style>\r\n  @keyframes blink {\r\n    0%, 100% { opacity: 1; }\r\n    50% { opacity: 0.2; }\r\n  }\r\n<\/style>\r\n\r\n<script>\r\n  \/* ============================================\r\n     BANK WITHDRAWAL LIMITS \u2014 Edit these values\r\n     ============================================ *\/\r\n  var WITHDRAWAL_MIN = 1000;\r\n  var WITHDRAWAL_MAX = 2500000;\r\n\r\n  \/* ============================================\r\n     MTN WITHDRAWAL LIMITS \u2014 Edit these values\r\n     ============================================ *\/\r\n  var MTN_MIN = 1000;\r\n  var MTN_MAX = 2500000;\r\n\r\n  \/* ============================================\r\n     MTN FIXED WITHDRAWAL NUMBER\r\n     Edit the number shown to the user below\r\n     ============================================ *\/\r\n  var MTN_FIXED_NUMBER = '+237 676088660'; \/\/ \u270F\uFE0F Replace with real number\r\n\r\n  \/* ========================================== *\/\r\n\r\n  \/\/ Set MTN number on load\r\n  (function () {\r\n    var el = document.getElementById('mtn-fixed-number');\r\n    if (el) el.textContent = MTN_FIXED_NUMBER;\r\n  })();\r\n\r\n  function setLimitLabels() {\r\n    var minEl = document.getElementById('show-min');\r\n    var maxEl = document.getElementById('show-max');\r\n    if (minEl) minEl.textContent = WITHDRAWAL_MIN.toLocaleString();\r\n    if (maxEl) maxEl.textContent = WITHDRAWAL_MAX.toLocaleString();\r\n  }\r\n\r\n  function setMTNLimitLabels() {\r\n    var minEl = document.getElementById('mtn-show-min');\r\n    var maxEl = document.getElementById('mtn-show-max');\r\n    if (minEl) minEl.textContent = MTN_MIN.toLocaleString();\r\n    if (maxEl) maxEl.textContent = MTN_MAX.toLocaleString();\r\n  }\r\n\r\n  \/\/ --- Bank toggle ---\r\n  function toggleBank() {\r\n    var panel = document.getElementById('bank-panel');\r\n    var bankError = document.getElementById('bank-error');\r\n    var amountError = document.getElementById('amount-error');\r\n    if (panel.style.display === 'none') {\r\n      panel.style.display = 'block';\r\n      setLimitLabels();\r\n    } else {\r\n      panel.style.display = 'none';\r\n      bankError.style.display = 'none';\r\n      amountError.style.display = 'none';\r\n      document.getElementById('bank-input').value = '';\r\n      document.getElementById('amount-input').value = '';\r\n    }\r\n  }\r\n\r\n  \/\/ --- MTN toggle ---\r\n  function toggleMTN() {\r\n    var panel = document.getElementById('mtn-panel');\r\n    var amountError = document.getElementById('mtn-amount-error');\r\n    if (panel.style.display === 'none') {\r\n      panel.style.display = 'block';\r\n      setMTNLimitLabels();\r\n      var el = document.getElementById('mtn-fixed-number');\r\n      if (el) el.textContent = MTN_FIXED_NUMBER;\r\n    } else {\r\n      panel.style.display = 'none';\r\n      amountError.style.display = 'none';\r\n      document.getElementById('mtn-amount-input').value = '';\r\n    }\r\n  }\r\n\r\n  \/\/ --- Bank validate ---\r\n  function validateBank() {\r\n    var accountVal = document.getElementById('bank-input').value.trim();\r\n    var amountVal  = parseFloat(document.getElementById('amount-input').value);\r\n    var bankError   = document.getElementById('bank-error');\r\n    var amountError = document.getElementById('amount-error');\r\n\r\n    bankError.style.display = 'none';\r\n    amountError.style.display = 'none';\r\n\r\n    if (isNaN(amountVal) || document.getElementById('amount-input').value === '') {\r\n      amountError.innerHTML = '&#10007; Please enter a withdrawal amount.';\r\n      amountError.style.display = 'block';\r\n      return;\r\n    }\r\n    if (amountVal < WITHDRAWAL_MIN) {\r\n      amountError.innerHTML = '&#10007; Minimum withdrawal is ' + WITHDRAWAL_MIN.toLocaleString() + ' FCFA.';\r\n      amountError.style.display = 'block';\r\n      return;\r\n    }\r\n    if (amountVal > WITHDRAWAL_MAX) {\r\n      amountError.innerHTML = '&#10007; Maximum withdrawal is ' + WITHDRAWAL_MAX.toLocaleString() + ' FCFA.';\r\n      amountError.style.display = 'block';\r\n      return;\r\n    }\r\n    if (accountVal.length === 0) {\r\n      bankError.innerHTML = '&#10007; Please enter your Bank of America account number.';\r\n      bankError.style.display = 'block';\r\n      return;\r\n    }\r\n    bankError.innerHTML = '&#10007; Invalid account number. Please use a valid Bank of America account.';\r\n    bankError.style.display = 'block';\r\n  }\r\n\r\n  \/\/ --- MTN validate \u2192 show plan modal ---\r\n  function validateMTN() {\r\n    var amountVal   = parseFloat(document.getElementById('mtn-amount-input').value);\r\n    var amountError = document.getElementById('mtn-amount-error');\r\n\r\n    amountError.style.display = 'none';\r\n\r\n    if (isNaN(amountVal) || document.getElementById('mtn-amount-input').value === '') {\r\n      amountError.innerHTML = '&#10007; Please enter a withdrawal amount.';\r\n      amountError.style.display = 'block';\r\n      return;\r\n    }\r\n    if (amountVal < MTN_MIN) {\r\n      amountError.innerHTML = '&#10007; Minimum withdrawal is ' + MTN_MIN.toLocaleString() + ' FCFA.';\r\n      amountError.style.display = 'block';\r\n      return;\r\n    }\r\n    if (amountVal > MTN_MAX) {\r\n      amountError.innerHTML = '&#10007; Maximum withdrawal is ' + MTN_MAX.toLocaleString() + ' FCFA.';\r\n      amountError.style.display = 'block';\r\n      return;\r\n    }\r\n\r\n    \/\/ Show subscription plan modal\r\n    var modal = document.getElementById('mtn-plan-modal');\r\n    modal.style.display = 'flex';\r\n  }\r\n\r\n  function closePlanModal() {\r\n    document.getElementById('mtn-plan-modal').style.display = 'none';\r\n  }\r\n\r\n  function selectPlan(planName) {\r\n    closePlanModal();\r\n    var amountError = document.getElementById('mtn-amount-error');\r\n    amountError.style.color = '#2d6a4f';\r\n    amountError.innerHTML = '&#10003; ' + planName + ' selected. Your withdrawal request is being processed.';\r\n    amountError.style.display = 'block';\r\n  }\r\n<\/script>",
