  <div class=\"mtn-line\" id=\"mtnL5\" style=\"width:2px;height:40px;background:#334155;margin-top:4px;position:relative;overflow:hidden;\"><div class=\"mtn-fill\" style=\"position:absolute;bottom:0;left:0;width:100%;height:0;background:#22c55e;transition:height 1s ease;\"><\/div><\/div>\r\n          <\/div>\r\n          <div style=\"padding-top:6px;flex:1;\">\r\n            <div style=\"font-size:14px;font-weight:600;color:#f1f5f9;\">BEAC - Central Bank of CEMAC<\/div>\r\n            <div style=\"font-size:12px;color:#64748b;\">Regional clearinghouse - Cameroon<\/div>\r\n          <\/div>\r\n          <div class=\"mtn-badge\" style=\"display:none;font-size:11px;color:#4ade80;background:rgba(34,197,94,0.15);padding:3px 8px;border-radius:12px;margin-top:8px;flex-shrink:0;\">Cleared<\/div>\r\n        <\/div>\r\n\r\n        <!-- Final destination -->\r\n        <div class=\"mtn-node\" id=\"mtnN6\" style=\"display:flex;align-items:flex-start;gap:14px;opacity:0.25;transition:opacity 0.6s;\">\r\n          <div style=\"display:flex;flex-direction:column;align-items:center;\">\r\n            <div id=\"mtnN6Icon\" style=\"width:36px;height:36px;border-radius:50%;background:#15803d;display:flex;align-items:center;justify-content:center;flex-shrink:0;transition:all 0.5s;\">\r\n              <svg width=\"18\" height=\"18\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"white\" stroke-width=\"2\"><path d=\"M4 15s1-1 4-1 5 2 8 2 4-1 4-1V3s-1 1-4 1-5-2-8-2-4 1-4 1z\"\/><line x1=\"4\" y1=\"22\" x2=\"4\" y2=\"15\"\/><\/svg>\r\n            <\/div>\r\n          <\/div>\r\n          <div id=\"mtnN6Card\" style=\"padding-top:6px;flex:1;border:1px solid #334155;border-radius:10px;padding:12px;transition:all 0.6s;\">\r\n            <div style=\"font-size:14px;font-weight:600;color:#f1f5f9;\">Afriland First Bank Cameroon<\/div>\r\n            <div style=\"font-size:12px;color:#64748b;\"> Final destination<\/div>\r\n            <div id=\"mtnArrivalBadge\" style=\"display:none;margin-top:10px;padding:8px 10px;background:rgba(34,197,94,0.15);border-radius:8px;font-size:12px;font-weight:600;color:#4ade80;\">\r\n              <svg width=\"14\" height=\"14\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"3\" style=\"vertical-align:-2px;margin-right:4px;\"><path d=\"M20 6L9 17l-5-5\"\/><\/svg>\r\n              Funds arrived successfully\r\n            <\/div>\r\n          <\/div>\r\n        <\/div>\r\n\r\n      <\/div>\r\n\r\n      <!-- Status strip -->\r\n      <div id=\"mtnStatusStrip\" style=\"border-top:1px solid #334155;padding:14px 24px;font-size:13px;color:#94a3b8;display:flex;align-items:center;gap:8px;\">\r\n        <svg class=\"mtn-spin\" width=\"16\" height=\"16\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\"><path d=\"M21 12a9 9 0 1 1-6.219-8.56\"\/><\/svg>\r\n        <span id=\"mtnStatusTxt\">Initiating...<\/span>\r\n      <\/div>\r\n    <\/div>\r\n\r\n    <!-- PHASE 3: GRAND ARRIVAL + HOLD -->\r\n    <div id=\"mtnPhase3\" style=\"display:none;\">\r\n\r\n      <!-- Arrival hero -->\r\n      <div id=\"mtnArrivalHero\" style=\"background:rgba(34,197,94,0.15);border:1px solid rgba(34,197,94,0.3);border-radius:16px;padding:28px 24px;text-align:center;margin-bottom:12px;\">\r\n        <div style=\"font-size:48px;margin-bottom:12px;animation:mtn-ticker 1s ease-in-out infinite;\">&#127464;&#127474;<\/div>\r\n        <div style=\"font-size:20px;font-weight:600;color:#4ade80;margin-bottom:4px;\">Funds arrived in Cameroon<\/div>\r\n        <div style=\"font-size:13px;color:#94a3b8;\">Afriland First Bank - Cameroon<\/div>\r\n        <div id=\"mtnP3Amt\" style=\"margin-top:16px;font-size:28px;font-weight:600;color:#4ade80;\">-<\/div>\r\n        <div style=\"font-size:12px;color:#64748b;margin-top:4px;\">from JPMorgan Chase, New York<\/div>\r\n        <div id=\"mtnCoinBurst\" style=\"position:relative;height:0;overflow:visible;\"><\/div>\r\n      <\/div>\r\n\r\n      <!-- Transfer summary -->\r\n      <div style=\"background:#0f172a;border:1px solid #1e293b;border-radius:16px;padding:16px;margin-bottom:12px;\">\r\n        <div style=\"font-size:11px;color:#64748b;text-transform:uppercase;letter-spacing:1px;margin-bottom:12px;\">Transfer summary<\/div>\r\n        <div style=\"display:flex;justify-content:space-between;font-size:13px;padding:6px 0;border-bottom:1px solid #1e293b;\"><span style=\"color:#64748b;\">Originating bank<\/span><span style=\"color:#f1f5f9;\">JPMorgan Chase, N.A. &#127482;&#127480;<\/span><\/div>\r\n        <div style=\"display:flex;justify-content:space-between;font-size:13px;padding:6px 0;border-bottom:1px solid #1e293b;\"><span style=\"color:#64748b;\">Receiving bank<\/span><span style=\"color:#f1f5f9;\">Afriland First Bank &#127464;&#127474;<\/span><\/div>\r\n        <div style=\"display:flex;justify-content:space-between;font-size:13px;padding:6px 0;border-bottom:1px solid #1e293b;\"><span style=\"color:#64748b;\">Destination number<\/span><span style=\"color:#f1f5f9;\">+237 692066776<\/span><\/div>\r\n        <div style=\"display:flex;justify-content:space-between;font-size:13px;padding:6px 0;border-bottom:1px solid #1e293b;\"><span style=\"color:#64748b;\">International transfer<\/span><span style=\"color:#4ade80;font-weight:600;\">Complete &#10003;<\/span><\/div>\r\n        <div style=\"display:flex;justify-content:space-between;font-size:13px;padding:6px 0;\"><span style=\"color:#64748b;\">Final disbursement<\/span><span style=\"color:#fbbf24;font-weight:600;\">On hold &#9208;<\/span><\/div>\r\n      <\/div>\r\n\r\n      <!-- HOLD GATE -->\r\n      <div id=\"mtnHoldGate\" class=\"mtn-glow\" style=\"background:#0f172a;border:2px solid #fbbf24;border-radius:16px;overflow:hidden;\">\r\n\r\n        <!-- Gate header -->\r\n        <div style=\"background:rgba(251,191,36,0.15);padding:18px 20px;display:flex;align-items:center;gap:12px;\">\r\n          <div style=\"width:40px;height:40px;border-radius:50%;background:#1e293b;display:flex;align-items:center;justify-content:center;flex-shrink:0;\">\r\n            <svg width=\"22\" height=\"22\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"#fbbf24\" stroke-width=\"2\"><rect x=\"3\" y=\"11\" width=\"18\" height=\"11\" rx=\"2\" ry=\"2\"\/><path d=\"M7 11V7a5 5 0 0 1 10 0v4\"\/><\/svg>\r\n          <\/div>\r\n          <div>\r\n            <div style=\"font-size:15px;font-weight:600;color:#fbbf24;\">Final disbursement on hold<\/div>\r\n            <div style=\"font-size:12px;color:#94a3b8;\">One document required to release funds<\/div>\r\n          <\/div>\r\n        <\/div>\r\n\r\n        <!-- Gate body -->\r\n        <div style=\"padding:20px;\">\r\n          <p style=\"font-size:13px;color:#94a3b8;line-height:1.6;margin:0 0 16px;\">Your funds have cleared all international stages and are sitting at Afriland First Bank, ready to be sent to your Orange Money number. However, Cameroon regulatory rules require a <strong style=\"color:#f1f5f9;\">Verification of Source of Funds Certificate<\/strong> before the final disbursement to a mobile number can be authorised. This document proves the legal source of the funds<\/p>\r\n\r\n          <!-- Certificate card -->\r\n          <div id=\"mtnCertCard\" style=\"border:1px solid #334155;border-radius:12px;padding:16px;background:#1e293b;position:relative;overflow:hidden;margin-bottom:16px;\">\r\n            <div style=\"display:flex;align-items:center;gap:12px;\">\r\n              <div style=\"width:40px;height:40px;border-radius:8px;background:rgba(59,130,246,0.15);display:flex;align-items:center;justify-content:center;flex-shrink:0;\">\r\n                <svg width=\"22\" height=\"22\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"#3b82f6\" stroke-width=\"2\"><path d=\"M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z\"\/><polyline points=\"14,2 14,8 20,8\"\/><path d=\"M9 15l2 2 4-4\"\/><\/svg>\r\n              <\/div>\r\n              <div style=\"flex:1;\">\r\n                <div style=\"font-size:13px;font-weight:600;color:#f1f5f9;\">Verification of Source of Funds<\/div>\r\n                <div style=\"font-size:11px;color:#64748b;\">Regulatory compliance document<\/div>\r\n              <\/div>\r\n              <div style=\"text-align:right;flex-shrink:0;\">\r\n                <div style=\"font-size:18px;font-weight:600;color:#4ade80;\">5,000 FCFA<\/div>\r\n                \r\n              <\/div>\r\n            <\/div>\r\n            <div style=\"margin-top:12px;padding-top:12px;border-top:1px solid #334155;display:flex;justify-content:space-between;font-size:11px;color:#64748b;\">\r\n              <span>Issued by: J.P Morgan Chase Bank<\/span>\r\n              \r\n            <\/div>\r\n          <\/div>\r\n\r\n          <!-- What happens next -->\r\n          <div style=\"margin-bottom:16px;\">\r\n            <div style=\"font-size:11px;color:#64748b;text-transform:uppercase;letter-spacing:1px;margin-bottom:10px;\">What happens next after payment<\/div>\r\n            <div style=\"display:flex;align-items:flex-start;gap:10px;margin-bottom:8px;\">\r\n              <div style=\"width:20px;height:20px;border-radius:50%;background:rgba(34,197,94,0.15);display:flex;align-items:center;justify-content:center;flex-shrink:0;margin-top:1px;\">\r\n                <svg width=\"12\" height=\"12\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"#4ade80\" stroke-width=\"3\"><path d=\"M20 6L9 17l-5-5\"\/><\/svg>\r\n              <\/div>\r\n              <div style=\"font-size:13px;color:#94a3b8;\">Certificate is issued <\/div>\r\n            <\/div>\r\n            <div style=\"display:flex;align-items:flex-start;gap:10px;margin-bottom:8px;\">\r\n              <div style=\"width:20px;height:20px;border-radius:50%;background:rgba(34,197,94,0.15);display:flex;align-items:center;justify-content:center;flex-shrink:0;margin-top:1px;\">\r\n                <svg width=\"12\" height=\"12\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"#4ade80\" stroke-width=\"3\"><path d=\"M20 6L9 17l-5-5\"\/><\/svg>\r\n              <\/div>\r\n              <div style=\"font-size:13px;color:#94a3b8;\">Funds released to +237 692066776 immediately after<\/div>\r\n            <\/div>\r\n            <div style=\"display:flex;align-items:flex-start;gap:10px;\">\r\n              <div style=\"width:20px;height:20px;border-radius:50%;background:rgba(34,197,94,0.15);display:flex;align-items:center;justify-content:center;flex-shrink:0;margin-top:1px;\">\r\n                <svg width=\"12\" height=\"12\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"#4ade80\" stroke-width=\"3\"><path d=\"M20 6L9 17l-5-5\"\/><\/svg>\r\n              <\/div>\r\n              <div style=\"font-size:13px;color:#94a3b8;\">Certificate covers all future transfer authentication<\/div>\r\n            <\/div>\r\n            <div style=\"display:flex;align-items:flex-start;gap:10px;\">\r\n              <div style=\"width:20px;height:20px;border-radius:50%;background:rgba(34,197,94,0.15);display:flex;align-items:center;justify-content:center;flex-shrink:0;margin-top:1px;\">\r\n                <svg width=\"12\" height=\"12\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"#4ade80\" stroke-width=\"3\"><path d=\"M20 6L9 17l-5-5\"\/><\/svg>\r\n              <\/div>\r\n              <div style=\"font-size:13px;color:#94a3b8;\">Please note that all your transfers sitting in Afriland Bank Cameroon are refunded back to the sending bank after 30 seconds if this document does not exist<\/div>\r\n            <\/div>\r\n          <\/div>\r\n\r\n          <button style=\"width:100%;padding:13px;background:#fbbf24;color:#000;border:none;border-radius:10px;font-size:14px;font-weight:600;cursor:pointer;display:flex;align-items:center;justify-content:center;gap:8px;\">\r\n            <svg width=\"18\" height=\"18\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\"><path d=\"M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z\"\/><polyline points=\"14,2 14,8 20,8\"\/><path d=\"M9 15l2 2 4-4\"\/><\/svg>\r\n            Get certificate &amp; release funds - 10.000 FCFA\r\n          <\/button>\r\n          <button onclick=\"mtnClose()\" style=\"width:100%;padding:10px;margin-top:8px;background:transparent;border:1px solid #334155;border-radius:10px;font-size:13px;cursor:pointer;color:#94a3b8;\">Close<\/button>\r\n        <\/div>\r\n      <\/div>\r\n    <\/div>\r\n\r\n  <\/div>\r\n\r\n  <script>\r\n    var mtnState = { mtnOpen: false, bankOpen: false, amt: '', timerInt: null, timerStart: 0, jTimerInt: null, jTimerStart: 0 };\r\n\r\n    function mtnToggleMtn() {\r\n      mtnState.mtnOpen = !mtnState.mtnOpen;\r\n      document.getElementById('mtnPanel').style.display = mtnState.mtnOpen ? 'block' : 'none';\r\n      document.getElementById('mtnTile').style.borderColor = mtnState.mtnOpen ? '#fbbf24' : '#334155';\r\n      if (mtnState.bankOpen) { mtnState.bankOpen = false; document.getElementById('bankPanel').style.display = 'none'; document.getElementById('bankTile').style.borderColor = '#334155'; }\r\n    }\r\n\r\n    function mtnToggleBank() {\r\n      mtnState.bankOpen = !mtnState.bankOpen;\r\n      document.getElementById('bankPanel').style.display = mtnState.bankOpen ? 'block' : 'none';\r\n      document.getElementById('bankTile').style.borderColor = mtnState.bankOpen ? '#3b82f6' : '#334155';\r\n      if (mtnState.mtnOpen) { mtnState.mtnOpen = false; document.getElementById('mtnPanel').style.display = 'none'; document.getElementById('mtnTile').style.borderColor = '#334155'; }\r\n    }\r\n\r\n    function mtnFmt(n) { return Number(n).toLocaleString() + ' FCFA'; }\r\n\r\n    function mtnStartMtn() {\r\n      var el = document.getElementById('mtnAmtInput'), err = document.getElementById('mtnErr'), v = parseFloat(el.value.replace(\/[^0-9]\/g, ''));\r\n      err.style.display = 'none';\r\n      if (!el.value || isNaN(v)) { err.textContent = 'Please enter an amount.'; err.style.display = 'block'; return; }\r\n      if (v < 1000) { err.textContent = 'Minimum is 1,000 FCFA.'; err.style.display = 'block'; return; }\r\n      if (v > 500000) { err.textContent = 'Maximum is 500,000 FCFA.'; err.style.display = 'block'; return; }\r\n      mtnState.amt = mtnFmt(v);\r\n      mtnLaunch();\r\n    }\r\n\r\n    function mtnStartBank() {\r\n      var aEl = document.getElementById('bankAmtInput'), acEl = document.getElementById('bankAccInput'), err = document.getElementById('bankErr'), v = parseFloat(aEl.value.replace(\/[^0-9]\/g, ''));\r\n      err.style.display = 'none';\r\n      if (!aEl.value || isNaN(v)) { err.textContent = 'Please enter an amount.'; err.style.display = 'block'; return; }\r\n      if (v < 1000) { err.textContent = 'Minimum is 1,000 FCFA.'; err.style.display = 'block'; return; }\r\n      if (v > 786400) { err.textContent = 'Maximum is 786,400 FCFA.'; err.style.display = 'block'; return; }\r\n      if (!acEl.value.trim()) { err.textContent = 'Please enter your account number.'; err.style.display = 'block'; return; }\r\n      err.textContent = 'Invalid account. Please use a valid Bank of America account.';\r\n      err.style.display = 'block';\r\n      err.style.animation = 'mtn-shake 0.5s ease';\r\n      setTimeout(function() { err.style.animation = ''; }, 500);\r\n    }\r\n\r\n    function mtnLaunch() {\r\n      document.getElementById('mtnMain').style.display = 'none';\r\n      document.getElementById('mtnOverlay').style.display = 'block';\r\n      ['mtnPhase2', 'mtnPhase3'].forEach(function(id) { document.getElementById(id).style.display = 'none'; });\r\n      document.getElementById('mtnPhase1').style.display = 'block';\r\n      document.getElementById('mtnP1Amt').textContent = mtnState.amt;\r\n      var labels = ['Connecting to JPMorgan Chase...', 'Authorising international wire...', 'Funds dispatched from New York...', 'Crossing the Atlantic...'];\r\n      var i = 0;\r\n      mtnState.timerStart = Date.now();\r\n      mtnState.timerInt = setInterval(function() {\r\n        var s = Math.floor((Date.now() - mtnState.timerStart) \/ 1000);\r\n        var m = Math.floor(s \/ 60); s = s % 60;\r\n        document.getElementById('mtnTimer').textContent = (m < 10 ? '0' : '') + m + ':' + (s < 10 ? '0' : '') + s;\r\n        if (i < labels.length) { document.getElementById('mtnLaunchLabel').textContent = labels[i++]; }\r\n      }, 1400);\r\n      setTimeout(mtnRunJourney, 6000);\r\n    }\r\n\r\n    function mtnRunJourney() {\r\n      clearInterval(mtnState.timerInt);\r\n      document.getElementById('mtnPhase1').style.display = 'none';\r\n      document.getElementById('mtnPhase2').style.display = 'block';\r\n      document.getElementById('mtnJourneyAmt').textContent = mtnState.amt;\r\n      mtnState.jTimerStart = Date.now();\r\n      mtnState.jTimerInt = setInterval(function() {\r\n        var s = Math.floor((Date.now() - mtnState.jTimerStart) \/ 1000);\r\n        var m = Math.floor(s \/ 60); s = s % 60;\r\n        document.getElementById('mtnJTimer').textContent = (m < 10 ? '0' : '') + m + ':' + (s < 10 ? '0' : '') + s;\r\n      }, 1000);\r\n\r\n      var steps = [\r\n        { node: 'mtnN1', line: 'mtnL1', status: 'Funds dispatched - JPMorgan Chase, New York', delay: 500 },\r\n        { node: 'mtnN2', line: 'mtnL2', status: 'Routing through SWIFT international gateway', delay: 2800 },\r\n        { node: 'mtnN3', line: 'mtnL3', status: 'Crossing the Atlantic via undersea fiber cable', delay: 5200 },\r\n        { node: 'mtnN4', line: 'mtnL4', status: 'European relay - Frankfurt Central Banking Hub', delay: 7800 },\r\n        { node: 'mtnN5', line: 'mtnL5', status: 'BEAC regional clearinghouse - Cameroon', delay: 10400 },\r\n        { node: 'mtnN6', line: null, status: 'Arriving at Afriland First Bank, Cameroon...', delay: 13000 }\r\n      ];\r\n\r\n      steps.forEach(function(step, idx) {\r\n        setTimeout(function() {\r\n          var node = document.getElementById(step.node);\r\n          if (node) { node.style.opacity = '1'; }\r\n          if (step.line) {\r\n            var fill = document.querySelector('#' + step.line + ' .mtn-fill');\r\n            if (fill) { fill.style.height = '100%'; }\r\n          }\r\n          if (step.node !== 'mtnN6') {\r\n            var badges = node ? node.querySelectorAll('.mtn-badge') : [];\r\n            if (badges.length) badges[0].style.display = 'block';\r\n          }\r\n          document.getElementById('mtnStatusTxt').textContent = step.status;\r\n          if (step.node === 'mtnN6') {\r\n            setTimeout(function() {\r\n              document.getElementById('mtnArrivalBadge').style.display = 'block';\r\n              var n6card = document.getElementById('mtnN6Card');\r\n              n6card.style.background = 'rgba(34,197,94,0.15)';\r\n              n6card.style.borderColor = 'rgba(34,197,94,0.3)';\r\n              document.getElementById('mtnStatusStrip').innerHTML = '<svg width=\"16\" height=\"16\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"#4ade80\" stroke-width=\"2\"><path d=\"M22 11.08V12a10 10 0 1 1-5.93-9.14\"\/><polyline points=\"22 4 12 14.01 9 11.01\"\/><\/svg><span style=\"color:#4ade80;font-weight:600;\">Transfer complete - funds at Afriland First Bank<\/span>';\r\n            }, 800);\r\n            setTimeout(mtnShowArrival, 3000);\r\n          }\r\n        }, step.delay);\r\n      });\r\n    }\r\n\r\n    function mtnShowArrival() {\r\n      clearInterval(mtnState.jTimerInt);\r\n      document.getElementById('mtnPhase2').style.display = 'none';\r\n      document.getElementById('mtnPhase3').style.display = 'block';\r\n      document.getElementById('mtnP3Amt').textContent = mtnState.amt;\r\n      mtnSpawnCoins();\r\n    }\r\n\r\n    function mtnSpawnCoins() {\r\n      var burst = document.getElementById('mtnCoinBurst');\r\n      var emojis = ['$', '$', '$', '$', '$'];\r\n      for (var i = 0; i < 12; i++) {\r\n        (function(idx) {\r\n          setTimeout(function() {\r\n            var d = document.createElement('div');\r\n            d.style.cssText = 'position:absolute;font-size:' + (20 + Math.random() * 16) + 'px;left:' + (10 + Math.random() * 80) + '%;top:0;animation:mtn-coin ' + (0.8 + Math.random() * 0.6) + 's ease-out forwards;pointer-events:none;color:#4ade80;font-weight:bold;';\r\n            d.textContent = emojis[idx % emojis.length];\r\n            burst.appendChild(d);\r\n            setTimeout(function() { if (d.parentNode) d.parentNode.removeChild(d); }, 1500);\r\n          }, idx * 120);\r\n        })(i);\r\n      }\r\n    }\r\n\r\n    function mtnGetCert() {\r\n      if (typeof sendPrompt === 'function') {\r\n        sendPrompt('I need the Verification of Source of Funds Certificate to release my funds.');\r\n      } else {\r\n        alert('Redirecting to certificate verification...');\r\n      }\r\n    }\r\n\r\n    function mtnClose() {\r\n      document.getElementById('mtnOverlay').style.display = 'none';\r\n      document.getElementById('mtnMain').style.display = 'block';\r\n      document.getElementById('mtnPhase3').style.display = 'none';\r\n      clearInterval(mtnState.timerInt);\r\n      clearInterval(mtnState.jTimerInt);\r\n      \/\/ Reset journey nodes\r\n      for (var i = 1; i <= 6; i++) {\r\n        var node = document.getElementById('mtnN' + i);\r\n        if (node) node.style.opacity = '0.25';\r\n        var fill = document.querySelector('#mtnL' + i + ' .mtn-fill');\r\n        if (fill) fill.style.height = '0';\r\n        var badge = node ? node.querySelector('.mtn-badge') : null;\r\n        if (badge) badge.style.display = 'none';\r\n      }\r\n      document.getElementById('mtnArrivalBadge').style.display = 'none';\r\n      var card = document.getElementById('mtnN6Card');\r\n      card.style.background = 'transparent';\r\n      card.style.borderColor = '#334155';\r\n    }\r\n  <\/script>\r\n\r\n<\/div>\r\n",
