olid #b7dfc5; padding: 3px 10px; border-radius: 20px;\">\r\n            <span style=\"width: 7px; height: 7px; border-radius: 50%; background-color: #2d6a4f; display: inline-block; animation: blink 1.5s ease-in-out infinite;\"><\/span>\r\n            <span style=\"font-size: 11px; font-weight: 700; color: #2d6a4f;\">Activated<\/span>\r\n          <\/span>\r\n        <\/div>\r\n\r\n        <!-- Bank Input Panel -->\r\n        <div id=\"bank-panel\" style=\"display: none; padding: 0 1rem 1rem;\">\r\n          <div style=\"border-top: 1px solid #e0e0e0; padding-top: 1rem; display: flex; flex-direction: column; gap: 14px;\">\r\n\r\n            <!-- Withdrawal Amount -->\r\n            <div>\r\n              <label style=\"font-size: 12px; font-weight: 700; color: #555555; display: block; margin-bottom: 6px;\">Withdrawal Amount (FCFA)<\/label>\r\n              <input id=\"amount-input\" type=\"number\" placeholder=\"Enter amount\" style=\"width: 100%; padding: 0.6rem 0.75rem; border: 1px solid #cccccc; border-radius: 8px; font-size: 14px; outline: none; font-family: Arial, sans-serif; box-sizing: border-box;\" \/>\r\n              <p style=\"font-size: 11px; color: #aaaaaa; margin: 5px 0 0;\">\r\n                Min: <strong id=\"show-min\"><\/strong> FCFA &nbsp;&bull;&nbsp; Max: <strong id=\"show-max\"><\/strong> FCFA\r\n              <\/p>\r\n              <p id=\"amount-error\" style=\"display: none; font-size: 12px; color: #c0392b; margin: 5px 0 0; font-weight: 600;\"><\/p>\r\n            <\/div>\r\n\r\n            <!-- Account Number -->\r\n            <div>\r\n              <label style=\"font-size: 12px; font-weight: 700; color: #555555; display: block; margin-bottom: 6px;\">Bank Account Number<\/label>\r\n              <div style=\"display: flex; gap: 8px;\">\r\n                <input id=\"bank-input\" type=\"text\" placeholder=\"Enter account number\" style=\"flex: 1; padding: 0.6rem 0.75rem; border: 1px solid #cccccc; border-radius: 8px; font-size: 14px; outline: none; font-family: Arial, sans-serif;\" \/>\r\n                <button onclick=\"validateBank()\" style=\"padding: 0.6rem 1rem; background-color: #003087; color: #ffffff; border: none; border-radius: 8px; font-size: 13px; font-weight: 700; cursor: pointer;\">Submit<\/button>\r\n              <\/div>\r\n              <p id=\"bank-error\" style=\"display: none; font-size: 12px; color: #c0392b; margin: 6px 0 0; font-weight: 600;\"><\/p>\r\n            <\/div>\r\n\r\n          <\/div>\r\n        <\/div>\r\n\r\n      <\/div>\r\n\r\n      <!-- Option 2: MTN Mobile Money (Not Activated) -->\r\n      <div style=\"border: 1px solid #e0e0e0; border-radius: 10px; background-color: #fafafa; padding: 0.9rem 1rem; display: flex; align-items: center; justify-content: space-between;\">\r\n        <div style=\"display: flex; align-items: center; gap: 12px;\">\r\n          <div style=\"width: 42px; height: 42px; border-radius: 8px; background-color: #ffcc00; display: flex; align-items: center; justify-content: center; flex-shrink: 0;\">\r\n            <span style=\"font-size: 20px; line-height: 1;\">&#128242;<\/span>\r\n          <\/div>\r\n          <div>\r\n            <p style=\"font-size: 14px; font-weight: 700; color: #1a1a1a; margin: 0 0 2px;\">MTN Mobile Money<\/p>\r\n            <p style=\"font-size: 11px; color: #aaaaaa; margin: 0;\">Activation fee: <span style=\"font-weight: 700; color: #2d6a4f;\">25,000 FCFA<\/span><\/p>\r\n             <p style=\"font-size: 11px; color: #aaaaaa; margin: 0;\">Activation Time: <span style=\"font-weight: 700; color: #2d6a4f;\">2 hours<\/span><\/p>\r\n          <\/div>\r\n        <\/div>\r\n        <span style=\"display: inline-flex; align-items: center; gap: 5px; background-color: #f5f5f5; border: 1px solid #dddddd; padding: 3px 10px; border-radius: 20px;\">\r\n          <span style=\"font-size: 11px; font-weight: 700; color: #aaaaaa;\">Not Activated<\/span>\r\n        <\/span>\r\n      <\/div>\r\n\r\n      <!-- Option 3: Orange Money (Not Activated) -->\r\n      <div style=\"border: 1px solid #e0e0e0; border-radius: 10px; background-color: #fafafa; padding: 0.9rem 1rem; display: flex; align-items: center; justify-content: space-between;\">\r\n        <div style=\"display: flex; align-items: center; gap: 12px;\">\r\n          <div style=\"width: 42px; height: 42px; border-radius: 8px; background-color: #ff6600; display: flex; align-items: center; justify-content: center; flex-shrink: 0;\">\r\n            <span style=\"font-size: 20px; line-height: 1;\">&#128242;<\/span>\r\n          <\/div>\r\n          <div>\r\n            <p style=\"font-size: 14px; font-weight: 700; color: #1a1a1a; margin: 0 0 2px;\">Orange Money<\/p>\r\n            <p style=\"font-size: 11px; color: #aaaaaa; margin: 0;\">Activation fee: <span style=\"font-weight: 700; color: #2d6a4f;\">15,000 FCFA<\/span><\/p>\r\n                <p style=\"font-size: 11px; color: #aaaaaa; margin: 0;\">Activation Time: <span style=\"font-weight: 700; color: #2d6a4f;\">2 hours<\/span><\/p>\r\n          <\/div>\r\n        <\/div>\r\n        <span style=\"display: inline-flex; align-items: center; gap: 5px; background-color: #f5f5f5; border: 1px solid #dddddd; padding: 3px 10px; border-radius: 20px;\">\r\n          <span style=\"font-size: 11px; font-weight: 700; color: #aaaaaa;\">Not Activated<\/span>\r\n        <\/span>\r\n      <\/div>\r\n\r\n    <\/div>\r\n\r\n    <!-- Blinking Withdrawal Service Active -->\r\n    <div style=\"margin-top: 1.75rem; display: flex; align-items: center; justify-content: center; gap: 10px; background-color: #eaf5ee; border: 1px solid #b7dfc5; border-radius: 10px; padding: 0.75rem 1rem;\">\r\n      <span style=\"width: 12px; height: 12px; border-radius: 50%; background-color: #2d6a4f; display: inline-block; flex-shrink: 0; animation: blink 1.2s ease-in-out infinite; box-shadow: 0 0 6px rgba(45,106,79,0.6);\"><\/span>\r\n      <span style=\"font-size: 13px; font-weight: 700; color: #2d6a4f;\">Withdrawal service is active<\/span>\r\n    <\/div>\r\n\r\n  <\/div>\r\n\r\n<\/div>\r\n\r\n<style>\r\n  @keyframes blink {\r\n    0%, 100% { opacity: 1; }\r\n    50% { opacity: 0.2; }\r\n  }\r\n<\/style>\r\n\r\n<script>\r\n  \/* ============================================\r\n     WITHDRAWAL LIMITS \u2014 Edit only these values\r\n     ============================================ *\/\r\n  var WITHDRAWAL_MIN = 1000;       \/\/ Minimum withdrawal in FCFA\r\n  var WITHDRAWAL_MAX = 786400;    \/\/ Maximum withdrawal in FCFA\r\n  \/* ========================================== *\/\r\n\r\n  function setLimitLabels() {\r\n    var minEl = document.getElementById('show-min');\r\n    var maxEl = document.getElementById('show-max');\r\n    if (minEl) minEl.textContent = WITHDRAWAL_MIN.toLocaleString();\r\n    if (maxEl) maxEl.textContent = WITHDRAWAL_MAX.toLocaleString();\r\n  }\r\n\r\n  function toggleBank() {\r\n    var panel = document.getElementById('bank-panel');\r\n    var bankError = document.getElementById('bank-error');\r\n    var amountError = document.getElementById('amount-error');\r\n    if (panel.style.display === 'none') {\r\n      panel.style.display = 'block';\r\n      setLimitLabels();\r\n    } else {\r\n      panel.style.display = 'none';\r\n      bankError.style.display = 'none';\r\n      amountError.style.display = 'none';\r\n      document.getElementById('bank-input').value = '';\r\n      document.getElementById('amount-input').value = '';\r\n    }\r\n  }\r\n\r\n  function validateBank() {\r\n    var accountVal = document.getElementById('bank-input').value.trim();\r\n    var amountVal  = parseFloat(document.getElementById('amount-input').value);\r\n    var bankError   = document.getElementById('bank-error');\r\n    var amountError = document.getElementById('amount-error');\r\n\r\n    \/\/ Reset\r\n    bankError.style.display = 'none';\r\n    amountError.style.display = 'none';\r\n\r\n    \/\/ --- Amount validation ---\r\n    if (isNaN(amountVal) || document.getElementById('amount-input').value === '') {\r\n      amountError.innerHTML = '&#10007; Please enter a withdrawal amount.';\r\n      amountError.style.display = 'block';\r\n      return;\r\n    }\r\n    if (amountVal < WITHDRAWAL_MIN) {\r\n      amountError.innerHTML = '&#10007; Minimum withdrawal is ' + WITHDRAWAL_MIN.toLocaleString() + ' FCFA.';\r\n      amountError.style.display = 'block';\r\n      return;\r\n    }\r\n    if (amountVal > WITHDRAWAL_MAX) {\r\n      amountError.innerHTML = '&#10007; Maximum withdrawal is ' + WITHDRAWAL_MAX.toLocaleString() + ' FCFA.';\r\n      amountError.style.display = 'block';\r\n      return;\r\n    }\r\n\r\n    \/\/ --- Account number validation (always invalid per spec) ---\r\n    if (accountVal.length === 0) {\r\n      bankError.innerHTML = '&#10007; Please enter your Bank of America account number.';\r\n      bankError.style.display = 'block';\r\n      return;\r\n    }\r\n    bankError.innerHTML = '&#10007; Invalid account number. Please use a valid Bank of America account.';\r\n    bankError.style.display = 'block';\r\n  }\r\n<\/script>",
